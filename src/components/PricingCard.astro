---
import Button from "./Button.astro";

interface Props {
	title: string;
	price: string;
	period?: string;
	description: string;
	features: string[];
	ctaText: string;
	ctaHref: string;
	variant?: "default" | "featured" | "secondary";
}

const {
	title,
	price,
	period,
	description,
	features,
	ctaText,
	ctaHref,
	variant = "default",
} = Astro.props;

const variantClasses = {
	default: "border border-slate-700 bg-slate-800",
	featured: "border-2 border-teal-brand bg-slate-800 shadow-teal-lg",
	secondary: "border border-slate-700 bg-midnight",
};
---

<div class={`rounded-xl p-8 ${variantClasses[variant]} ${variant === "featured" ? "scale-105" : ""}`}>
	<h3 class="text-2xl font-bold text-slate-50 mb-2">{title}</h3>
	<div class="mb-4">
		<span class="text-4xl font-bold text-slate-50">{price}</span>
		{period && <span class="text-slate-400 ml-2">{period}</span>}
	</div>
	<p class="text-slate-400 mb-6">{description}</p>

	<ul class="space-y-3 mb-8">
		{features.map((feature) => (
			<li class="flex items-start gap-3 text-slate-300">
				<svg aria-hidden="true" class="w-5 h-5 text-teal-brand flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
				</svg>
				<span>{feature}</span>
			</li>
		))}
	</ul>

	<Button variant={variant === "featured" ? "primary" : "outline"} size="lg" href={ctaHref} class="w-full">
		{ctaText}
	</Button>
</div>
