---
import Button from "./Button.astro";

interface Props {
	title: string;
	price: string;
	period?: string;
	description: string;
	features: string[];
	ctaText: string;
	ctaHref: string;
	variant?: "default" | "featured" | "secondary";
}

const {
	title,
	price,
	period,
	description,
	features,
	ctaText,
	ctaHref,
	variant = "default",
} = Astro.props;

const variantClasses = {
	default: "border border-gray-800 bg-black",
	featured: "border-2 border-primary-red bg-black shadow-[0_0_30px_rgba(230,57,70,0.3)]",
	secondary: "border border-gray-800 bg-gray-900",
};
---

<div class={`rounded-xl p-8 ${variantClasses[variant]} ${variant === "featured" ? "scale-105" : ""}`}>
	<h3 class="text-2xl font-bold text-white mb-2">{title}</h3>
	<div class="mb-4">
		<span class="text-4xl font-bold text-white">{price}</span>
		{period && <span class="text-gray-400 ml-2">{period}</span>}
	</div>
	<p class="text-gray-400 mb-6">{description}</p>

	<ul class="space-y-3 mb-8">
		{features.map((feature) => (
			<li class="flex items-start gap-3 text-gray-300">
				<svg class="w-5 h-5 text-primary-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
				</svg>
				<span>{feature}</span>
			</li>
		))}
	</ul>

	<Button variant={variant === "featured" ? "primary" : "outline"} size="lg" href={ctaHref} class="w-full">
		{ctaText}
	</Button>
</div>
