---
interface Props {
	variant?: "default" | "primary" | "success" | "warning" | "error" | "info";
	size?: "sm" | "md";
	class?: string;
}

const {
	variant = "default",
	size = "md",
	class: className,
} = Astro.props;

const baseClasses = "inline-flex items-center rounded-full font-medium";

const variantClasses = {
	default: "bg-slate-800 text-slate-300 border border-slate-700",
	primary: "bg-teal-light text-teal-brand border border-teal-brand/20",
	success: "bg-green-900/20 text-code-green border border-green-900/30",
	warning: "bg-amber-900/20 text-amber-400 border border-amber-900/30",
	error: "bg-red-900/20 text-red-400 border border-red-900/30",
	info: "bg-blue-900/20 text-blue-400 border border-blue-900/30",
};

const sizeClasses = {
	sm: "px-2 py-0.5 text-xs",
	md: "px-2.5 py-1 text-sm",
};

const combinedClasses = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className || ""}`;
---

<span class={combinedClasses}>
	<slot />
</span>
