---
interface Props {
	variant?: "default" | "primary" | "success" | "warning" | "error";
	size?: "sm" | "md";
	class?: string;
}

const {
	variant = "default",
	size = "md",
	class: className,
} = Astro.props;

const baseClasses = "inline-flex items-center rounded-full font-medium";

const variantClasses = {
	default: "bg-gray-800 text-gray-300 border border-gray-700",
	primary: "bg-primary-red-light text-primary-red border border-primary-red/20",
	success: "bg-green-900/20 text-green-400 border border-green-900/30",
	warning: "bg-yellow-900/20 text-yellow-400 border border-yellow-900/30",
	error: "bg-red-900/20 text-red-400 border border-red-900/30",
};

const sizeClasses = {
	sm: "px-2 py-0.5 text-xs",
	md: "px-2.5 py-1 text-sm",
};

const combinedClasses = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className || ""}`;

{/*
Usage:
<Badge variant="primary">New</Badge>
<Badge variant="success" size="sm">Active</Badge>
*/}

---

<span class={combinedClasses}>
	<slot />
</span>
