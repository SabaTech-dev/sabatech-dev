---
import Badge from "./Badge.astro";
import Button from "./Button.astro";

interface Props {
	badge?: string;
	headline: string;
	subheadline?: string;
	ctaText: string;
	ctaHref: string;
	secondaryCtaText?: string;
	secondaryCtaHref?: string;
	variant?: "default" | "gradient" | "dark";
}

const {
	badge,
	headline,
	subheadline,
	ctaText,
	ctaHref,
	secondaryCtaText,
	secondaryCtaHref,
	variant = "default",
} = Astro.props;

const variantClasses = {
	default: "bg-midnight",
	gradient: "bg-dark-depth",
	dark: "bg-midnight",
};
---

<section class={`${variantClasses[variant]} py-20 md:py-32 relative overflow-hidden`}>
	<!-- Subtle grid pattern background -->
	<div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#94A3B8 1px, transparent 1px), linear-gradient(90deg, #94A3B8 1px, transparent 1px); background-size: 60px 60px;"></div>
	<!-- AI Glow effect -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-ai-glow pointer-events-none"></div>

	<div class="container mx-auto px-4 max-w-7xl relative">
		<div class="text-center">
			{badge && <Badge variant="primary" class="mb-6">{badge}</Badge>}
			<h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold mb-6 text-slate-50 leading-tight">
				{headline}
			</h1>
			{subheadline && (
				<p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-3xl mx-auto leading-relaxed">
					{subheadline}
				</p>
			)}
			<div class="flex flex-col sm:flex-row gap-4 justify-center mt-12">
				<Button variant="primary" size="lg" href={ctaHref}>
					{ctaText}
				</Button>
				{secondaryCtaText && secondaryCtaHref && (
					<Button variant="outline" size="lg" href={secondaryCtaHref}>
						{secondaryCtaText}
					</Button>
				)}
			</div>
		</div>
	</div>
</section>
