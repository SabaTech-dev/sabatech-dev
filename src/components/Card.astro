---
interface Props {
	variant?: "default" | "elevated" | "bordered";
	hover?: boolean;
	class?: string;
}

const {
	variant = "default",
	hover = false,
	class: className,
} = Astro.props;

const baseClasses = "rounded-lg overflow-hidden";

const variantClasses = {
	default: "bg-slate-800",
	elevated: "bg-slate-800/80 shadow-xl border border-slate-700/50",
	bordered: "bg-slate-800 border border-slate-700",
};

const hoverClasses = hover
	? "hover:shadow-2xl hover:-translate-y-1 hover:border-teal-brand/30 transition-all duration-300"
	: "";

const combinedClasses = `${baseClasses} ${variantClasses[variant]} ${hoverClasses} ${className || ""}`;
---

<div class={combinedClasses}>
	<slot />
</div>
