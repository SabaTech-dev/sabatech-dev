---
interface Props {
	size?: "sm" | "md" | "lg" | "xl" | "full";
	class?: string;
}

const {
	size = "xl",
	class: className,
} = Astro.props;

const sizeClasses = {
	sm: "max-w-3xl",
	md: "max-w-4xl",
	lg: "max-w-6xl",
	xl: "max-w-7xl",
	full: "max-w-full",
};

const combinedClasses = `container mx-auto px-4 sm:px-6 lg:px-8 ${sizeClasses[size]} ${className || ""}`;

{/*
Usage:
<Container>
	<h1>Content</h1>
</Container>

<Container size="md">
	<p>Centered content</p>
</Container>
*/}

---

<div class={combinedClasses}>
	<slot />
</div>
