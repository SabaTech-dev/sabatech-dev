  <!-- Hero -->
  <section class="bg-dark-depth py-20 md:py-32 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#94A3B8 1px, transparent 1px), linear-gradient(90deg, #94A3B8 1px, transparent 1px); background-size: 60px 60px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-ai-glow pointer-events-none"></div>

    <div class="container mx-auto px-4 max-w-7xl relative">
      <div class="text-center">
        <Badge variant="primary" class="mb-6" data-i18n="llmtrain.badge">LLM Fine-Tuning Pipeline</Badge>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold mb-6 text-slate-50 leading-tight">
          <span data-i18n="llmtrain.hero.title1">Saba-LLM-Auto-Train</span><br />
          <span class="bg-clip-text text-transparent bg-saba-gradient" data-i18n="llmtrain.hero.title2">Domain-Adapted AI Agents</span>
        </h1>
        <p data-i18n="llmtrain.hero.desc" class="text-lg md:text-xl text-slate-400 mb-12 max-w-3xl mx-auto leading-relaxed">
          Automated pipeline that fine-tunes Google Gemma-4 E2B with Alfred agent data using QLoRA. Our model now speaks SabaTech — understanding our tools, services, architecture, and workflows.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button variant="primary" size="lg" href="/saba-llm-auto-train/report" data-i18n="llmtrain.hero.cta">View Benchmark Report</Button>
          <Button variant="outline" size="lg" href="https://github.com/SabaTech-dev/saba-llm-auto-train" target="_blank">GitHub →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <Section variant="light" padding="lg">
    <div class="max-w-4xl mx-auto">
      <h2 data-i18n="llmtrain.overview.title" class="text-3xl md:text-4xl font-bold mb-6 text-slate-50 text-center">Project Overview</h2>
      <p data-i18n="llmtrain.overview.desc" class="text-slate-400 text-lg leading-relaxed text-center">
        Saba-LLM-Auto-Train is an end-to-end pipeline that extracts knowledge from Alfred's operational data (daily logs, memory files, tool outputs, training documents) and uses it to fine-tune a Gemma-4 LLM via QLoRA 4-bit quantization. The result: a domain-specialized model that understands the Saba Agent OS ecosystem intimately.
      </p>
    </div>

    <!-- Pipeline Steps Visual -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mt-12">
      <div class="text-center p-6">
        <div class="w-14 h-14 rounded-xl bg-teal-light flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
          </svg>
        </div>
        <span class="text-xs font-mono text-teal-brand">1. Extract</span>
        <p class="text-sm text-slate-500 mt-1">Alfred memory → JSONL</p>
      </div>
      <div class="text-center p-6">
        <div class="w-14 h-14 rounded-xl bg-teal-light flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <span class="text-xs font-mono text-teal-brand">2. Train</span>
        <p class="text-sm text-slate-500 mt-1">QLoRA 4-bit NF4</p>
      </div>
      <div class="text-center p-6">
        <div class="w-14 h-14 rounded-xl bg-teal-light flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
          </svg>
        </div>
        <span class="text-xs font-mono text-teal-brand">3. Export</span>
        <p class="text-sm text-slate-500 mt-1">GGUF Q4_K_M</p>
      </div>
      <div class="text-center p-6">
        <div class="w-14 h-14 rounded-xl bg-teal-light flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <span class="text-xs font-mono text-teal-brand">4. Deploy</span>
        <p class="text-sm text-slate-500 mt-1">Ollama + Inference</p>
      </div>
    </div>
  </Section>

  <!-- Technical Stack -->
  <Section variant="dark" padding="lg">
    <div class="text-center mb-16">
      <h2 data-i18n="llmtrain.tech.title" class="text-3xl md:text-5xl font-bold mb-4 text-slate-50">Technical Stack</h2>
      <p data-i18n="llmtrain.tech.desc" class="text-slate-400 text-lg max-w-2xl mx-auto">
        From data extraction to deployment — a complete MLOps pipeline
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <Card variant="elevated" hover>
        <div class="p-6">
          <div class="w-12 h-12 rounded-lg bg-teal-light flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
            </svg>
          </div>
          <h3 data-i18n="llmtrain.tech.data" class="text-lg font-bold mb-2 text-slate-50">Data Pipeline</h3>
          <p data-i18n="llmtrain.tech.data.desc" class="text-sm text-slate-400 leading-relaxed">
            Extracts instruction-formatted data from agent memory, daily notes, and wiki documents. Automatic train/val splitting.
          </p>
        </div>
      </Card>

      <Card variant="elevated" hover>
        <div class="p-6">
          <div class="w-12 h-12 rounded-lg bg-teal-light flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 data-i18n="llmtrain.tech.train" class="text-lg font-bold mb-2 text-slate-50">QLoRA Training</h3>
          <p data-i18n="llmtrain.tech.train.desc" class="text-sm text-slate-400 leading-relaxed">
            4-bit NF4 quantization, LoRA adapters on all attention + feed-forward projections. Cosine LR schedule with warmup.
          </p>
        </div>
      </Card>

      <Card variant="elevated" hover>
        <div class="p-6">
          <div class="w-12 h-12 rounded-lg bg-teal-light flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
            </svg>
          </div>
          <h3 data-i18n="llmtrain.tech.export" class="text-lg font-bold mb-2 text-slate-50">Export & Deploy</h3>
          <p data-i18n="llmtrain.tech.export.desc" class="text-sm text-slate-400 leading-relaxed">
            Merges LoRA weights, quantizes to GGUF Q4_K_M, and deploys as an Ollama model. Ready for inference.
          </p>
        </div>
      </Card>

      <Card variant="elevated" hover>
        <div class="p-6">
          <div class="w-12 h-12 rounded-lg bg-teal-light flex items-center justify-center mb-4">
