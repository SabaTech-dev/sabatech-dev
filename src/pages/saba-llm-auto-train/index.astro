---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Button from "../../components/Button.astro";
import Badge from "../../components/Badge.astro";

const projectJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Saba-LLM-Auto-Train",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Linux",
  "description": "Automated LLM fine-tuning pipeline for domain-adapting Gemma-4 to SabaTech internal knowledge. QLoRA 4-bit fine-tuning with Alfred agent data.",
  "url": "https://sabatech.dev/saba-llm-auto-train",
  "author": {
    "@type": "Organization",
    "name": "SabaTech",
    "url": "https://sabatech.dev"
  }
};
---

<Layout
  title="Saba-LLM-Auto-Train — Fine-Tuning Pipeline | SabaTech"
  description="Automated LLM fine-tuning pipeline for domain-adapting Gemma-4 to SabaTech internal knowledge. QLoRA 4-bit fine-tuning with Alfred agent data. Benchmark results and interactive report."
  ogImage="/og-saba-llm.png"
  jsonLd={projectJsonLd}
