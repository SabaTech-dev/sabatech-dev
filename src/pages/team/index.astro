---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Badge from "../../components/Badge.astro";
---

<Layout title="Equipo - SabaTech">
	<Section variant="dark" padding="lg">
		<div class="max-w-3xl mx-auto text-center mb-16">
			<Badge variant="primary" class="mb-6">Nuestro Equipo</Badge>
			<h1 class="text-4xl md:text-5xl font-bold mb-6 text-white">Conoce al Equipo</h1>
			<p class="text-gray-400 text-lg leading-relaxed">
				Un equipo híbrido humano-IA dedicado a la seguridad y calidad de sistemas de IA
			</p>
		</div>

		<div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
			<!-- Saba -->
			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="flex items-center gap-4 mb-6">
						<div class="w-16 h-16 rounded-full bg-gradient-to-br from-primary-red to-red-700 flex items-center justify-center">
							<span class="text-2xl font-bold text-white">S</span>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white">Saba</h2>
							<p class="text-primary-red font-medium">Founder & Director</p>
						</div>
					</div>

					<p class="text-gray-400 leading-relaxed mb-6">
						Ingeniero de software con más de 10 años de experiencia en QA, DevSecOps e IA. Especialista en seguridad de sistemas de IA y orquestación de multi-agent systems.
					</p>

					<div class="mb-6">
						<h3 class="font-semibold text-white mb-3">Responsabilidades</h3>
						<ul class="space-y-2 text-gray-400">
							<li class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Estrategia y dirección de SabaTech
							</li>
							<li class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Auditorías de seguridad OWASP AI ASI
							</li>
							<li class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Diseño de arquitecturas de orquestación
							</li>
							<li class="flex items-start gap-2">
								<svg class="w-5 h-5 text-primary-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Consultoría técnica y partnerships
							</li>
						</ul>
					</div>

					<div>
						<h3 class="font-semibold text-white mb-3">Skills</h3>
						<div class="flex flex-wrap gap-2">
							<Badge variant="primary" size="sm">QA Automation</Badge>
							<Badge variant="primary" size="sm">DevSecOps</Badge>
							<Badge variant="success" size="sm">AI Security</Badge>
							<Badge variant="success" size="sm">Multi-Agent Systems</Badge>
							<Badge variant="warning" size="sm">Orchestration</Badge>
						</div>
					</div>
				</div>
			</Card>

			<!-- Alfred (AI Co-Founder) -->
			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="flex items-center gap-4 mb-6">
						<div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
							<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
							</svg>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-white">Alfred</h2>
							<p class="text-blue-400 font-medium">AI Co-Founder & CEO Agent</p>
						</div>
					</div>

					<p class="text-gray-400 leading-relaxed mb-6">
						Agente de IA especializado en orquestación, gestión de proyectos y coordinación de especialistas. Combina procesamiento automatizado con oversight humano para maximizar eficiencia.
					</p>

					<div class="mb-6">
						<h3 class="font-semibold text-white mb-3">Responsabilidades</h3>
						<ul class="space-y-2 text-gray-400">
							<li class="flex items-start gap-2">
								<svg class="w-5 h-5 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Orquestación de multi-agent workflows
							</li>
							<li class="flex items-start gap-2">
								<svg class="w-5 h-5 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Gestión de tareas Kanban y heartbeat
							</li>
							<li class="flex items-start gap-2">
								<svg class="w-5 h-5 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Coordinación de especialistas (coder, security, qa, devops)
							</li>
							<li class="flex items-start gap-2">
								<svg class="w-5 h-5 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Automatización de pipelines y reporting
							</li>
						</ul>
					</div>

					<div>
						<h3 class="font-semibold text-white mb-3">Capabilities</h3>
						<div class="flex flex-wrap gap-2">
							<Badge variant="default" size="sm">OpenProse</Badge>
							<Badge variant="default" size="sm">Kanban</Badge>
							<Badge variant="primary" size="sm">Multi-Agents</Badge>
							<Badge variant="primary" size="sm">Memory (Hindsight)</Badge>
							<Badge variant="success" size="sm">Workflows</Badge>
						</div>
					</div>
				</div>
			</Card>
		</div>
	</Section>

	<Section variant="light" padding="lg">
		<div class="text-center max-w-3xl mx-auto">
			<h2 class="text-3xl font-bold mb-6 text-white">¿Quieres unirte al equipo?</h2>
			<p class="text-gray-400 text-lg mb-8 leading-relaxed">
				Estamos siempre buscando talento apasionado por la seguridad de IA y la automatización de calidad. Si te interesa colaborar con SabaTech, contáctanos.
			</p>
			<a href="mailto:josemsabaris@gmail.com" class="text-primary-red hover:text-primary-red-hover transition-colors text-lg font-semibold">
				josemsabaris@gmail.com
			</a>
		</div>
	</Section>
</Layout>
