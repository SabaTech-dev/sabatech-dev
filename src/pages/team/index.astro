---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Badge from "../../components/Badge.astro";
import Button from "../../components/Button.astro";
---

<Layout title="Team — SabaTech" description="Meet the SabaTech hybrid human-AI team. Saba (Founder) + Alfred (AI Co-Founder) and 5 specialized AI agents for QA & Security.">
	<script id="i18n-page-translations" type="application/json" set:html={JSON.stringify({
		en: {
			"team.badge": "Our Team",
			"team.hero.title": "The Hybrid Team",
			"team.hero.desc": "A hybrid human-AI team dedicated to the security and quality of AI systems. 6 specialized AI agents + human oversight at every critical decision.",
			"team.agents.badge": "AI Agent Team",
			"team.agents.title": "5 Specialized AI Agents",
			"team.agents.subtitle": "Meet the team that works 24/7 — coordinated by Alfred, overseen by Saba.",
			"team.how.badge": "How It Works",
			"team.how.title": "How the Hybrid Team Works",
			"team.how.subtitle": "From task arrival to human review — a transparent, repeatable workflow that combines AI speed with human judgment.",
			"team.how.step1.title": "Task Arrives",
			"team.how.step1.desc": "Whether it's a security audit, QA run, or code review, the task enters the system and is queued for analysis.",
			"team.how.step2.title": "Alfred Assigns",
			"team.how.step2.desc": "The CEO agent analyzes requirements, determines the right specialist, and routes the task with full context and priority.",
			"team.how.step3.title": "Agent Executes",
			"team.how.step3.desc": "The specialist agent works on the task with full tool access — running scans, writing code, or executing test suites autonomously.",
			"team.how.step4.title": "Human Reviews",
			"team.how.step4.desc": "Saba reviews critical decisions, approves deliverables, and ensures quality standards are met before anything ships.",
			"team.join.badge": "Join Us",
			"team.join.title": "Want to join the team?",
			"team.join.desc": "We're always looking for talent passionate about AI security and quality automation. If you're interested in collaborating with SabaTech, reach out.",
			"team.join.cta1": "Get in Touch",
			"team.join.cta2": "Learn More About Us"
		},
		es: {
			"team.badge": "Nuestro Equipo",
			"team.hero.title": "El Equipo Híbrido",
			"team.hero.desc": "Un equipo híbrido humano-IA dedicado a la seguridad y calidad de los sistemas de IA. 6 agentes de IA especializados + supervisión humana en cada decisión crítica.",
			"team.agents.badge": "Equipo de Agentes IA",
			"team.agents.title": "5 Agentes de IA Especializados",
			"team.agents.subtitle": "Conoce al equipo que trabaja 24/7 — coordinado por Alfred, supervisado por Saba.",
			"team.how.badge": "Cómo Funciona",
			"team.how.title": "Cómo Funciona el Equipo Híbrido",
			"team.how.subtitle": "Desde la llegada de la tarea hasta la revisión humana — un flujo de trabajo transparente y repetible que combina velocidad IA con juicio humano.",
			"team.how.step1.title": "Llega la Tarea",
			"team.how.step1.desc": "Ya sea una auditoría de seguridad, ejecución de QA o revisión de código, la tarea entra al sistema y se encola para su análisis.",
			"team.how.step2.title": "Alfred Asigna",
			"team.how.step2.desc": "El agente CEO analiza los requisitos, determina el especialista adecuado y enruta la tarea con contexto completo y prioridad.",
			"team.how.step3.title": "El Agente Ejecuta",
			"team.how.step3.desc": "El agente especialista trabaja en la tarea con acceso completo a herramientas — ejecutando escaneos, escribiendo código o ejecutando suites de tests de forma autónoma.",
			"team.how.step4.title": "Revisión Humana",
			"team.how.step4.desc": "Saba revisa las decisiones críticas, aprueba los entregables y asegura que se cumplan los estándares de calidad antes de que nada se publique.",
			"team.join.badge": "Únete",
			"team.join.title": "¿Quieres unirte al equipo?",
			"team.join.desc": "Siempre buscamos talento apasionado por la seguridad en IA y la automatización de calidad. Si te interesa colaborar con SabaTech, ponte en contacto.",
			"team.join.cta1": "Contactar",
			"team.join.cta2": "Más Sobre Nosotros"
		}
	})} />
	<Section variant="dark" padding="lg">
		<div class="max-w-3xl mx-auto text-center mb-16">
			<Badge variant="primary" class="mb-6" data-i18n="team.badge">Our Team</Badge>
			<h1 class="text-4xl md:text-5xl font-extrabold mb-6 text-slate-50" data-i18n="team.hero.title">The Hybrid Team</h1>
			<p class="text-slate-400 text-lg leading-relaxed" data-i18n="team.hero.desc">
				A hybrid human-AI team dedicated to the security and quality of AI systems. 6 specialized AI agents + human oversight at every critical decision.
			</p>
		</div>

		<!-- Human + AI Co-Founder -->
		<div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto mb-16">
			<!-- Saba -->
			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="flex items-center gap-4 mb-6">
						<div class="w-16 h-16 rounded-full bg-saba-gradient flex items-center justify-center">
							<span class="text-2xl font-bold text-white">S</span>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-slate-50">Saba</h2>
							<p class="text-teal-brand font-medium">Founder & Director</p>
						</div>
					</div>

					<p class="text-slate-400 leading-relaxed mb-6">
						Tech Lead in AI Agentic & Generative AI | QA Lead Automation | DevSecOps at Minsait. Software engineer with 10+ years of experience in QA, DevSecOps, and AI. Specialist in AI system security, multi-agent orchestration, and enterprise AI enablement. Known in the community as "Joker," he brings deep expertise in building secure, scalable, high-quality systems where autonomous AI agents and human judgment work together.
					</p>

					<div class="mb-6">
						<h3 class="font-semibold text-slate-200 mb-3">Responsibilities</h3>
						<ul class="space-y-2 text-slate-400">
							<li class="flex items-start gap-2">
								<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								AI Enablement — evangelizing AI at all organizational levels, optimizing workflows
							</li>
							<li class="flex items-start gap-2">
								<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Innovation & Co-creation — disruptive PoCs, multi-agent systems, Generative AI
							</li>
							<li class="flex items-start gap-2">
								<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Tech Scouting — constant radar of AI/tech global news
							</li>
							<li class="flex items-start gap-2">
								<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Governance, QA & DevSecOps — Secure-by-Design, quality, predictability
							</li>
							<li class="flex items-start gap-2">
								<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Client engagement and delivery quality assurance
							</li>
						</ul>
					</div>

					<div>
						<h3 class="font-semibold text-slate-200 mb-3">Skills</h3>
						<div class="flex flex-wrap gap-2">
							<Badge variant="primary" size="sm">Tech Lead Minsait</Badge>
							<Badge variant="primary" size="sm">AI Enablement</Badge>
							<Badge variant="success" size="sm">AI Security</Badge>
							<Badge variant="success" size="sm">Multi-Agent Systems</Badge>
							<Badge variant="warning" size="sm">Orchestration</Badge>
							<Badge variant="warning" size="sm">DevSecOps</Badge>
							<Badge variant="info" size="sm">Tech Scouting</Badge>
							<Badge variant="info" size="sm">Innovation</Badge>
						</div>
					</div>
				</div>
			</Card>

			<!-- Alfred (AI Co-Founder) -->
			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="flex items-center gap-4 mb-6">
						<div class="w-16 h-16 rounded-full bg-saba-gradient flex items-center justify-center">
							<span class="text-2xl">🎯</span>
						</div>
						<div>
							<h2 class="text-2xl font-bold text-slate-50">Alfred</h2>
							<p class="text-teal-brand font-medium">AI Co-Founder & CEO Agent</p>
						</div>
					</div>

					<p class="text-slate-400 leading-relaxed mb-6">
						AI agent specialized in orchestration, project management, and specialist coordination. Alfred acts as the central nervous system of the team — analyzing incoming tasks, routing them to the right specialist agents, tracking progress through Kanban workflows, and maintaining shared memory across all operations. Combines automated processing with human oversight to maximize efficiency.
					</p>

					<div class="mb-6">
						<h3 class="font-semibold text-slate-200 mb-3">Responsibilities</h3>
						<ul class="space-y-2 text-slate-400">
							<li class="flex items-start gap-2">
								<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Multi-agent workflow orchestration and task routing
							</li>
							<li class="flex items-start gap-2">
								<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Kanban task management, heartbeat monitoring, and status reporting
							</li>
							<li class="flex items-start gap-2">
								<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Specialist coordination across coder, security, QA, and DevOps agents
							</li>
							<li class="flex items-start gap-2">
								<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Pipeline automation, CI/CD integration, and cross-agent memory management
							</li>
						</ul>
					</div>

					<div>
						<h3 class="font-semibold text-slate-200 mb-3">Capabilities</h3>
						<div class="flex flex-wrap gap-2">
							<Badge variant="default" size="sm">OpenProse</Badge>
							<Badge variant="default" size="sm">Kanban</Badge>
							<Badge variant="primary" size="sm">Multi-Agent Routing</Badge>
							<Badge variant="primary" size="sm">Shared Memory</Badge>
							<Badge variant="success" size="sm">Workflow Engine</Badge>
							<Badge variant="success" size="sm">CI/CD Integration</Badge>
						</div>
					</div>
				</div>
			</Card>
		</div>

		<!-- AI Agent Team -->
		<div class="text-center mb-12">
			<Badge variant="primary" class="mb-6" data-i18n="team.agents.badge">AI Agent Team</Badge>
			<h2 class="text-3xl md:text-4xl font-bold text-slate-50" data-i18n="team.agents.title">5 Specialized AI Agents</h2>
			<p class="text-slate-400 text-lg mt-4 max-w-2xl mx-auto" data-i18n="team.agents.subtitle">
				Meet the team that works 24/7 — coordinated by Alfred, overseen by Saba.
			</p>
		</div>

		<div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-8">
			<Card variant="elevated" hover>
				<div class="p-6 text-center">
					<div class="w-14 h-14 rounded-full bg-teal-light flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl">🔧</span>
					</div>
					<h3 class="text-lg font-bold text-slate-50 mb-2">Coder</h3>
					<p class="text-slate-400 text-sm mb-4">Implementation, refactoring, and feature development. Writes production-ready code following clean architecture principles and established conventions.</p>
					<div class="flex flex-wrap gap-1.5 justify-center">
						<Badge variant="primary" size="sm">Clean Architecture</Badge>
						<Badge variant="default" size="sm">Refactoring</Badge>
						<Badge variant="default" size="sm">Feature Dev</Badge>
					</div>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-6 text-center">
					<div class="w-14 h-14 rounded-full bg-teal-light flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl">🛡️</span>
					</div>
					<h3 class="text-lg font-bold text-slate-50 mb-2">Security</h3>
					<p class="text-slate-400 text-sm mb-4">Security audits, penetration testing, and vulnerability analysis. OWASP compliance expert specializing in AI-specific attack vectors and threat landscapes.</p>
					<div class="flex flex-wrap gap-1.5 justify-center">
						<Badge variant="error" size="sm">OWASP</Badge>
						<Badge variant="error" size="sm">Pentesting</Badge>
						<Badge variant="warning" size="sm">AI Threats</Badge>
					</div>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-6 text-center">
					<div class="w-14 h-14 rounded-full bg-teal-light flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl">🧪</span>
					</div>
					<h3 class="text-lg font-bold text-slate-50 mb-2">QA Tester</h3>
					<p class="text-slate-400 text-sm mb-4">End-to-end testing, coverage optimization, and regression detection. Quality gate enforcer ensuring zero-defect releases with automated test suites.</p>
					<div class="flex flex-wrap gap-1.5 justify-center">
						<Badge variant="success" size="sm">E2E Testing</Badge>
						<Badge variant="success" size="sm">Coverage</Badge>
						<Badge variant="primary" size="sm">Regression</Badge>
					</div>
				</div>
			</Card>
		</div>

		<div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
			<Card variant="elevated" hover>
				<div class="p-6 text-center">
					<div class="w-14 h-14 rounded-full bg-teal-light flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl">🚀</span>
					</div>
					<h3 class="text-lg font-bold text-slate-50 mb-2">DevOps</h3>
					<p class="text-slate-400 text-sm mb-4">CI/CD pipeline management, container orchestration, and infrastructure automation. Keeps deployment pipelines fast, reliable, and secure across all environments.</p>
					<div class="flex flex-wrap gap-1.5 justify-center">
						<Badge variant="info" size="sm">CI/CD</Badge>
						<Badge variant="info" size="sm">Containers</Badge>
						<Badge variant="default" size="sm">Infrastructure</Badge>
					</div>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-6 text-center">
					<div class="w-14 h-14 rounded-full bg-teal-light flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl">📚</span>
					</div>
					<h3 class="text-lg font-bold text-slate-50 mb-2">Research</h3>
					<p class="text-slate-400 text-sm mb-4">Continuous analysis of emerging threats, industry benchmarks, and best practices. Produces documentation, security reports, and keeps the team ahead of the curve.</p>
					<div class="flex flex-wrap gap-1.5 justify-center">
						<Badge variant="warning" size="sm">Threat Intel</Badge>
						<Badge variant="warning" size="sm">Benchmarks</Badge>
						<Badge variant="default" size="sm">Documentation</Badge>
					</div>
				</div>
			</Card>
		</div>

		<!-- External Agent -->
		<div class="mt-8 max-w-md mx-auto">
			<div class="text-center mb-6">
				<Badge variant="default" class="mb-3">External Agent</Badge>
			</div>
			<Card variant="elevated" hover>
				<div class="p-6 text-center">
					<div class="w-14 h-14 rounded-full bg-teal-light flex items-center justify-center mx-auto mb-4">
						<span class="text-2xl">💻</span>
					</div>
					<h3 class="text-lg font-bold text-slate-50 mb-2">OpenCode</h3>
					<p class="text-xs text-teal-brand font-medium mb-3">External Coding Agent</p>
					<p class="text-slate-400 text-sm mb-4">External coding agent powered by deepseek-v4-flash. Used for rapid code implementation, security review, and QA testing via spec-driven development (SDD). Integrates with OpenSpec for structured workflows.</p>
					<div class="flex flex-wrap gap-1.5 justify-center">
						<Badge variant="primary" size="sm">SDD</Badge>
						<Badge variant="default" size="sm">OpenSpec</Badge>
						<Badge variant="success" size="sm">Code Review</Badge>
						<Badge variant="warning" size="sm">QA Testing</Badge>
					</div>
				</div>
			</Card>
		</div>
	</Section>

	<!-- How the Hybrid Team Works -->
	<Section variant="light" padding="lg">
		<div class="text-center mb-12">
			<Badge variant="primary" class="mb-6" data-i18n="team.how.badge">How It Works</Badge>
			<h2 class="text-3xl md:text-4xl font-bold text-slate-50 mb-4" data-i18n="team.how.title">How the Hybrid Team Works</h2>
			<p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="team.how.subtitle">
				From task arrival to human review — a transparent, repeatable workflow that combines AI speed with human judgment.
			</p>
		</div>

		<div class="grid md:grid-cols-4 gap-6 max-w-5xl mx-auto">
			<!-- Step 1 -->
			<div class="relative text-center">
				<div class="w-12 h-12 rounded-full bg-teal-brand text-midnight flex items-center justify-center mx-auto mb-4 text-xl font-bold">1</div>
				<h3 class="text-lg font-bold text-slate-50 mb-2" data-i18n="team.how.step1.title">Task Arrives</h3>
				<p class="text-slate-400 text-sm" data-i18n="team.how.step1.desc">Whether it's a security audit, QA run, or code review, the task enters the system and is queued for analysis.</p>
			</div>

			<!-- Step 2 -->
			<div class="relative text-center">
				<div class="w-12 h-12 rounded-full bg-teal-brand text-midnight flex items-center justify-center mx-auto mb-4 text-xl font-bold">2</div>
				<h3 class="text-lg font-bold text-slate-50 mb-2" data-i18n="team.how.step2.title">Alfred Assigns</h3>
				<p class="text-slate-400 text-sm" data-i18n="team.how.step2.desc">The CEO agent analyzes requirements, determines the right specialist, and routes the task with full context and priority.</p>
			</div>

			<!-- Step 3 -->
			<div class="relative text-center">
				<div class="w-12 h-12 rounded-full bg-teal-brand text-midnight flex items-center justify-center mx-auto mb-4 text-xl font-bold">3</div>
				<h3 class="text-lg font-bold text-slate-50 mb-2" data-i18n="team.how.step3.title">Agent Executes</h3>
				<p class="text-slate-400 text-sm" data-i18n="team.how.step3.desc">The specialist agent works on the task with full tool access — running scans, writing code, or executing test suites autonomously.</p>
			</div>

			<!-- Step 4 -->
			<div class="relative text-center">
				<div class="w-12 h-12 rounded-full bg-teal-brand text-midnight flex items-center justify-center mx-auto mb-4 text-xl font-bold">4</div>
				<h3 class="text-lg font-bold text-slate-50 mb-2" data-i18n="team.how.step4.title">Human Reviews</h3>
				<p class="text-slate-400 text-sm" data-i18n="team.how.step4.desc">Saba reviews critical decisions, approves deliverables, and ensures quality standards are met before anything ships.</p>
			</div>
		</div>

		<div class="flex justify-center mt-8 gap-3">
			<div class="w-3 h-3 rounded-full bg-teal-brand"></div>
			<div class="w-16 h-0.5 bg-slate-600 self-center"></div>
			<div class="w-3 h-3 rounded-full bg-teal-brand/80"></div>
			<div class="w-16 h-0.5 bg-slate-600 self-center"></div>
			<div class="w-3 h-3 rounded-full bg-teal-brand/60"></div>
			<div class="w-16 h-0.5 bg-slate-600 self-center"></div>
			<div class="w-3 h-3 rounded-full bg-teal-brand/40"></div>
		</div>
	</Section>

	<Section variant="dark" padding="lg">
		<div class="text-center max-w-3xl mx-auto">
			<Badge variant="primary" class="mb-6" data-i18n="team.join.badge">Join Us</Badge>
			<h2 class="text-3xl font-bold mb-6 text-slate-50" data-i18n="team.join.title">Want to join the team?</h2>
			<p class="text-slate-400 text-lg mb-8 leading-relaxed" data-i18n="team.join.desc">
				We're always looking for talent passionate about AI security and quality automation. If you're interested in collaborating with SabaTech, reach out.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<Button variant="primary" size="lg" href="mailto:jmsabaris@sabatech.dev" data-i18n="team.join.cta1">
					Get in Touch
				</Button>
				<Button variant="outline" size="lg" href="/about" data-i18n="team.join.cta2">
					Learn More About Us
				</Button>
			</div>
		</div>
	</Section>
</Layout>
