---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Button from "../../components/Button.astro";
import Badge from "../../components/Badge.astro";
---

<Layout title="AI Orchestration — SabaTech" description="Multi-agent orchestration for AI systems. Design, implement, and scale autonomous agent architectures with SabaTech's hybrid human-AI team.">
  <script id="i18n-page-translations" type="application/json" set:html={JSON.stringify({
    en: {
      "orchestration.badge": "Multi-Agent Systems",
      "orchestration.hero.title1": "AI",
      "orchestration.hero.title2": "Orchestration",
      "orchestration.hero.subtitle": "Your AI workforce for software quality & security",
      "orchestration.hero.desc": "Alfred and his team of 5 specialized AI agents collaborate 24/7 — coordinated by AI, overseen by humans at every critical decision.",
      "orchestration.hero.cta1": "Book Assessment",
      "orchestration.hero.cta2": "See Architecture",
      "orchestration.arch.badge": "Architecture",
      "orchestration.arch.title": "Multi-Agent Topology",
      "orchestration.arch.subtitle": "Alfred orchestrates 5 specialized agents in a hub-and-spoke pattern with real-time event-driven communication",
      "orchestration.metrics.agents": "Agents Active",
      "orchestration.metrics.operation": "Operation",
      "orchestration.metrics.uptime": "Uptime",
      "orchestration.metrics.response": "Response Time",
      "orchestration.stack.badge": "Technology Stack",
      "orchestration.stack.title": "Built With",
      "orchestration.stack.subtitle": "Our orchestration layer is powered by purpose-built tools",
      "orchestration.services.title": "Orchestration Services",
      "orchestration.services.subtitle": "Scalable architectures to coordinate multiple autonomous agents",
      "orchestration.process.badge": "How It Works",
      "orchestration.process.title": "Our Process",
      "orchestration.process.subtitle": "From discovery to continuous improvement — a proven engagement model",
      "orchestration.pricing.title": "Orchestration Plans",
      "orchestration.pricing.subtitle": "Choose the engagement level that fits your needs",
      "orchestration.cases.badge": "Case Studies",
      "orchestration.cases.title": "Client Stories",
      "orchestration.cases.subtitle": "Real results from real engagements",
      "orchestration.cta.title": "Ready to orchestrate your AI systems?",
      "orchestration.cta.desc": "Get a free consultation on designing and implementing scalable, secure orchestration architectures.",
      "orchestration.cta.cta1": "Book Assessment"
    },
    es: {
      "orchestration.badge": "Sistemas Multiagente",
      "orchestration.hero.title1": "Orquestación",
      "orchestration.hero.title2": "IA",
      "orchestration.hero.subtitle": "Tu fuerza laboral de IA para calidad y seguridad del software",
      "orchestration.hero.desc": "Alfred y su equipo de 5 agentes de IA especializados colaboran 24/7 — coordinados por IA, supervisados por humanos en cada decisión crítica.",
      "orchestration.hero.cta1": "Reservar Evaluación",
      "orchestration.hero.cta2": "Ver Arquitectura",
      "orchestration.arch.badge": "Arquitectura",
      "orchestration.arch.title": "Topología Multiagente",
      "orchestration.arch.subtitle": "Alfred orquesta 5 agentes especializados en un patrón hub-and-spoke con comunicación event-driven en tiempo real",
      "orchestration.metrics.agents": "Agentes Activos",
      "orchestration.metrics.operation": "Operación",
      "orchestration.metrics.uptime": "Disponibilidad",
      "orchestration.metrics.response": "Tiempo de Respuesta",
      "orchestration.stack.badge": "Stack Tecnológico",
      "orchestration.stack.title": "Construido Con",
      "orchestration.stack.subtitle": "Nuestra capa de orquestación está impulsada por herramientas diseñadas a medida",
      "orchestration.services.title": "Servicios de Orquestación",
      "orchestration.services.subtitle": "Arquitecturas escalables para coordinar múltiples agentes autónomos",
      "orchestration.process.badge": "Cómo Funciona",
      "orchestration.process.title": "Nuestro Proceso",
      "orchestration.process.subtitle": "Desde el descubrimiento hasta la mejora continua — un modelo de engagement probado",
      "orchestration.pricing.title": "Planes de Orquestación",
      "orchestration.pricing.subtitle": "Elige el nivel de engagement que mejor se adapte a tus necesidades",
      "orchestration.cases.badge": "Casos de Uso",
      "orchestration.cases.title": "Historias de Clientes",
      "orchestration.cases.subtitle": "Resultados reales de proyectos reales",
      "orchestration.cta.title": "¿Listo para orquestar tus sistemas de IA?",
      "orchestration.cta.desc": "Obtén una consulta gratuita sobre diseño e implementación de arquitecturas de orquestación escalables y seguras.",
      "orchestration.cta.cta1": "Reservar Evaluación"
