  })} />
  <!-- Hero -->
  <Section variant="gradient" padding="xl">
    <div class="text-center">
      <Badge variant="primary" class="mb-6" data-i18n="orchestration.badge">Multi-Agent Systems</Badge>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold mb-6 text-slate-50" data-i18n="orchestration.hero.title1">
        AI <span class="bg-clip-text text-transparent bg-saba-gradient" data-i18n="orchestration.hero.title2">Orchestration</span>
      </h1>
      <p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-3xl mx-auto leading-relaxed" data-i18n="orchestration.hero.subtitle">
        Your AI workforce for software quality & security
      </p>
      <p class="text-lg text-slate-400 mb-12 max-w-2xl mx-auto" data-i18n="orchestration.hero.desc">
        Alfred and his team of 5 specialized AI agents collaborate 24/7 — coordinated by AI, overseen by humans at every critical decision.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button variant="primary" size="lg" href="/contact" data-i18n="orchestration.hero.cta1">Book Assessment</Button>
        <Button variant="outline" size="lg" href="#architecture" data-i18n="orchestration.hero.cta2">See Architecture</Button>
      </div>
    </div>
  </Section>

  <!-- 3.1 Architecture Visualization -->
  <Section variant="dark" padding="lg" id="architecture">
    <div class="text-center mb-16">
      <Badge variant="primary" class="mb-6" data-i18n="orchestration.arch.badge">Architecture</Badge>
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-slate-50" data-i18n="orchestration.arch.title">Multi-Agent Topology</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="orchestration.arch.subtitle">
        Alfred orchestrates 5 specialized agents in a hub-and-spoke pattern with real-time event-driven communication
      </p>
    </div>

    <!-- Architecture SVG Diagram -->
    <div class="max-w-4xl mx-auto">
      <div class="rounded-2xl bg-slate-800/50 border border-slate-700 p-8 md:p-12">
        <svg viewBox="0 0 600 400" class="w-full h-auto" xmlns="http://www.w3.org/2000/svg">
          <!-- Connection lines -->
          <line x1="300" y1="120" x2="120" y2="260" stroke="#06B6D4" stroke-width="2" stroke-dasharray="6,4" opacity="0.5"/>
          <line x1="300" y1="120" x2="240" y2="300" stroke="#06B6D4" stroke-width="2" stroke-dasharray="6,4" opacity="0.5"/>
          <line x1="300" y1="120" x2="360" y2="300" stroke="#06B6D4" stroke-width="2" stroke-dasharray="6,4" opacity="0.5"/>
          <line x1="300" y1="120" x2="480" y2="260" stroke="#06B6D4" stroke-width="2" stroke-dasharray="6,4" opacity="0.5"/>
          <line x1="300" y1="120" x2="300" y2="320" stroke="#06B6D4" stroke-width="2" stroke-dasharray="6,4" opacity="0.5"/>

          <!-- Alfred (CEO Agent) - Center Top -->
          <circle cx="300" cy="80" r="45" fill="#0F172A" stroke="#06B6D4" stroke-width="3"/>
          <text x="300" y="74" text-anchor="middle" fill="#06B6D4" font-size="24">🎯</text>
          <text x="300" y="94" text-anchor="middle" fill="#F8FAFC" font-size="10" font-weight="600">Alfred</text>
          <text x="300" y="140" text-anchor="middle" fill="#94A3B8" font-size="10">CEO Agent</text>

          <!-- Coder -->
          <circle cx="120" cy="260" r="38" fill="#0F172A" stroke="#06B6D4" stroke-width="2"/>
          <text x="120" y="255" text-anchor="middle" fill="#06B6D4" font-size="20">🔧</text>
          <text x="120" y="275" text-anchor="middle" fill="#F8FAFC" font-size="9" font-weight="600">Coder</text>
          <text x="120" y="310" text-anchor="middle" fill="#94A3B8" font-size="9">Implementation</text>

          <!-- Security -->
          <circle cx="240" cy="300" r="38" fill="#0F172A" stroke="#06B6D4" stroke-width="2"/>
          <text x="240" y="295" text-anchor="middle" fill="#06B6D4" font-size="20">🛡️</text>
          <text x="240" y="315" text-anchor="middle" fill="#F8FAFC" font-size="9" font-weight="600">Security</text>
          <text x="240" y="350" text-anchor="middle" fill="#94A3B8" font-size="9">Audits & Pentesting</text>

          <!-- QA Tester -->
          <circle cx="360" cy="300" r="38" fill="#0F172A" stroke="#06B6D4" stroke-width="2"/>
          <text x="360" y="295" text-anchor="middle" fill="#06B6D4" font-size="20">🧪</text>
          <text x="360" y="315" text-anchor="middle" fill="#F8FAFC" font-size="9" font-weight="600">QA Tester</text>
          <text x="360" y="350" text-anchor="middle" fill="#94A3B8" font-size="9">E2E Testing</text>

          <!-- DevOps -->
          <circle cx="480" cy="260" r="38" fill="#0F172A" stroke="#06B6D4" stroke-width="2"/>
          <text x="480" y="255" text-anchor="middle" fill="#06B6D4" font-size="20">🚀</text>
          <text x="480" y="275" text-anchor="middle" fill="#F8FAFC" font-size="9" font-weight="600">DevOps</text>
          <text x="480" y="310" text-anchor="middle" fill="#94A3B8" font-size="9">CI/CD & Deploy</text>

          <!-- Research -->
          <circle cx="300" cy="330" r="38" fill="#0F172A" stroke="#06B6D4" stroke-width="2"/>
          <text x="300" y="325" text-anchor="middle" fill="#06B6D4" font-size="20">📚</text>
          <text x="300" y="345" text-anchor="middle" fill="#F8FAFC" font-size="9" font-weight="600">Research</text>
          <text x="300" y="380" text-anchor="middle" fill="#94A3B8" font-size="9">Analysis & Intel</text>

          <!-- Labels -->
          <rect x="440" y="150" width="130" height="30" rx="6" fill="rgba(6,182,212,0.1)" stroke="rgba(6,182,212,0.3)" stroke-width="1"/>
          <text x="505" y="170" text-anchor="middle" fill="#06B6D4" font-size="10">Event-Driven</text>

          <rect x="30" y="150" width="130" height="30" rx="6" fill="rgba(132,204,22,0.1)" stroke="rgba(132,204,22,0.3)" stroke-width="1"/>
          <text x="95" y="170" text-anchor="middle" fill="#84CC16" font-size="10">Human Oversight</text>
        </svg>
      </div>
    </div>
  </Section>

  <!-- 3.3 Animated Metrics -->
  <Section variant="light" padding="lg">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-5xl mx-auto">
      <div class="text-center p-6 rounded-xl bg-slate-800/50 border border-slate-700">
        <div class="text-4xl md:text-5xl font-extrabold text-teal-brand mb-2">6</div>
        <p class="text-slate-400 text-sm" data-i18n="orchestration.metrics.agents">Agents Active</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-slate-800/50 border border-slate-700">
        <div class="text-4xl md:text-5xl font-extrabold text-teal-brand mb-2">24/7</div>
        <p class="text-slate-400 text-sm" data-i18n="orchestration.metrics.operation">Operation</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-slate-800/50 border border-slate-700">
        <div class="text-4xl md:text-5xl font-extrabold text-teal-brand mb-2">99.9%</div>
        <p class="text-slate-400 text-sm" data-i18n="orchestration.metrics.uptime">Uptime</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-slate-800/50 border border-slate-700">
        <div class="text-4xl md:text-5xl font-extrabold text-teal-brand mb-2">&lt;30s</div>
        <p class="text-slate-400 text-sm" data-i18n="orchestration.metrics.response">Response Time</p>
      </div>
    </div>
  </Section>

  <!-- 3.2 Technology Stack -->
  <Section variant="dark" padding="lg" id="stack">
    <div class="text-center mb-16">
      <Badge variant="primary" class="mb-6" data-i18n="orchestration.stack.badge">Technology Stack</Badge>
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-slate-50" data-i18n="orchestration.stack.title">Built With</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="orchestration.stack.subtitle">
        Our orchestration layer is powered by purpose-built tools
      </p>
    </div>

    <div class="grid md:grid-cols-3 lg:grid-cols-6 gap-6 max-w-6xl mx-auto">
      {[
        { name: "OpenClaw", desc: "Legal & compliance analysis engine", icon: "⚖️" },
        { name: "OpenProse", desc: "Natural language orchestration", icon: "📝" },
        { name: "Hindsight", desc: "Agent memory & learning system", icon: "🧠" },
        { name: "Mission Control", desc: "Real-time agent dashboard", icon: "🎛️" },
        { name: "Engram", desc: "Persistent memory across sessions", icon: "💾" },
        { name: "OpenCode", desc: "External coding agent (SDD workflows)", icon: "💻" },
      ].map((tech) => (
        <Card variant="elevated" hover>
          <div class="p-6 text-center">
            <div class="text-3xl mb-3">{tech.icon}</div>
            <h3 class="text-lg font-bold text-slate-50 mb-2">{tech.name}</h3>
            <p class="text-slate-400 text-sm">{tech.desc}</p>
          </div>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Orchestration Services (existing) -->
  <Section variant="light" padding="lg" id="services">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-slate-50" data-i18n="orchestration.services.title">Orchestration Services</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="orchestration.services.subtitle">
        Scalable architectures to coordinate multiple autonomous agents
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <Card variant="elevated" hover>
        <div class="p-8">
          <div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-slate-50">Architecture Design</h3>
          <p class="text-slate-400 mb-6">Design orchestration architectures for multi-agent systems. Pattern definition, topology, and agent roles.</p>
          <Badge variant="primary">System Design</Badge>
        </div>
      </Card>

      <Card variant="elevated" hover>
        <div class="p-8">
          <div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-slate-50">Workflow Automation</h3>
          <p class="text-slate-400 mb-6">Automate complex workflows with specialized agents. Parallel execution, dependency management, and retry logic.</p>
          <Badge variant="success">Automation</Badge>
        </div>
      </Card>

      <Card variant="elevated" hover>
        <div class="p-8">
          <div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-slate-50">Agent Coordination</h3>
          <p class="text-slate-400 mb-6">Coordinate multiple agents with secure communication and sync. Event-driven architecture patterns.</p>
          <Badge variant="primary">Coordination</Badge>
        </div>
      </Card>

      <Card variant="elevated" hover>
        <div class="p-8">
          <div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-slate-50">Monitoring & Observability</h3>
          <p class="text-slate-400 mb-6">Real-time dashboards for agents, workflows, and metrics. Logging, tracing, and alerting built-in.</p>
          <Badge variant="default">Observability</Badge>
        </div>
      </Card>

      <Card variant="elevated" hover>
        <div class="p-8">
          <div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-slate-50">Security Orchestration</h3>
          <p class="text-slate-400 mb-6">Secure inter-agent communication. Encryption, authentication, and RBAC for distributed systems.</p>
          <Badge variant="error">Security First</Badge>
        </div>
      </Card>

      <Card variant="elevated" hover>
        <div class="p-8">
          <div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-slate-50">Scaling & Performance</h3>
          <p class="text-slate-400 mb-6">Horizontal scaling of agents and workflows. Load balancing, caching, and optimization.</p>
          <Badge variant="success">Scalable</Badge>
        </div>
      </Card>
    </div>
  </Section>

  <!-- 3.6 Process Section -->
  <Section variant="dark" padding="lg" id="process">
    <div class="text-center mb-16">
      <Badge variant="primary" class="mb-6" data-i18n="orchestration.process.badge">How It Works</Badge>
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-slate-50" data-i18n="orchestration.process.title">Our Process</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="orchestration.process.subtitle">
        From discovery to continuous improvement — a proven engagement model
      </p>
    </div>

    <div class="grid md:grid-cols-4 gap-6 max-w-6xl mx-auto">
      {[
        { step: "1", title: "Discovery", desc: "We analyze your current AI infrastructure, identify gaps, and define orchestration goals.", icon: "🔍" },
        { step: "2", title: "Setup", desc: "Design and deploy the multi-agent architecture. Configure workflows, communication, and monitoring.", icon: "⚙️" },
        { step: "3", title: "Operation", desc: "Agents go live with 24/7 operation. Human oversight at every critical decision point.", icon: "🚀" },
        { step: "4", title: "Continuous Improvement", desc: "Ongoing optimization, agent learning, and adaptation based on performance metrics.", icon: "📈" },
      ].map((item) => (
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-saba-gradient text-white flex items-center justify-center mx-auto mb-4 font-bold text-xl">
            {item.step}
          </div>
          <h3 class="text-xl font-bold text-slate-50 mb-3">{item.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- 3.4 Service Pricing -->
  <Section variant="light" padding="lg" id="pricing">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-slate-50" data-i18n="orchestration.pricing.title">Orchestration Plans</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="orchestration.pricing.subtitle">
        Choose the engagement level that fits your needs
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <!-- Setup Básico -->
      <Card variant="elevated">
        <div class="p-8 flex flex-col h-full">
          <h3 class="text-2xl font-bold text-slate-50 mb-2">Setup Básico</h3>
          <p class="text-slate-400 mb-4">Get started with agent orchestration</p>
          <div class="flex items-baseline gap-1 mb-6">
            <span class="text-4xl font-bold text-slate-50">€499</span>
            <span class="text-slate-400">/setup</span>
          </div>
          <ul class="space-y-3 mb-8 flex-grow">
            <li class="flex items-start gap-3 text-slate-400">
