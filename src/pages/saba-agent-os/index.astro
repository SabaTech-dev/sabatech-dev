  <!-- Hero -->
  <Section variant="gradient" padding="xl">
    <div class="text-center">
      <Badge variant="primary" class="mb-6" data-i18n="sabaos.badge">Agent OS — v1.0</Badge>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold mb-6 text-slate-50" data-i18n="sabaos.hero.title1">
        Saba-Agent-OS
      </h1>
      <p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-3xl mx-auto leading-relaxed" data-i18n="sabaos.hero.title2">
        The Operating System for Your AI Workforce
      </p>
      <p class="text-lg text-slate-400 mb-6 max-w-2xl mx-auto" data-i18n="sabaos.hero.subtitle">
        Open-source, self-hosted orchestration for 6 specialized AI agents — memory, security, CI/CD, and feedback loops.
      </p>
      <p class="text-md text-slate-400 mb-12 max-w-2xl mx-auto" data-i18n="sabaos.hero.desc">
        Alfred leads 5 specialized agents in a 7-layer architecture. Code → Security → QA → Deploy — all autonomous, with human oversight at every critical decision.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button variant="primary" size="lg" href="https://github.com/SabaTech-dev/Saba-Agent-Os" data-i18n="sabaos.hero.cta1">Download Free</Button>
        <Button variant="outline" size="lg" href="#architecture" data-i18n="sabaos.hero.cta2">See Architecture</Button>
      </div>
    </div>
  </Section>

  <!-- 7-Layer Blueprint -->
