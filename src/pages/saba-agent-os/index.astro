        <p class="text-slate-400 text-sm" data-i18n="sabaos.metrics.tasks">Tasks/Month</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-slate-800/50 border border-slate-700">
        <div class="text-4xl md:text-5xl font-extrabold text-teal-brand mb-2">99.9%</div>
        <p class="text-slate-400 text-sm" data-i18n="sabaos.metrics.uptime">Uptime</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-slate-800/50 border border-slate-700">
