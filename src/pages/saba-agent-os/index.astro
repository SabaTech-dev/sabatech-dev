      <p class="text-slate-400 text-lg max-w-3xl mx-auto" data-i18n="sabaos.arch.subtitle">
        Inspired by Julian Goldie's blueprint — adapted as 100% open-source, self-hosted, with security pipeline and memory-first architecture.
      </p>
    </div>

    <!-- 7 Layers Visual -->
    <div class="max-w-5xl mx-auto">
      {[
        { l: 7, title: "sabaos.layer7.title", desc: "sabaos.layer7.desc", icon: "🔄", color: "from-purple-500 to-pink-500", status: "Live" },
        { l: 6, title: "sabaos.layer6.title", desc: "sabaos.layer6.desc", icon: "🚀", color: "from-blue-500 to-cyan-500", status: "Live" },
        { l: 5, title: "sabaos.layer5.title", desc: "sabaos.layer5.desc", icon: "🎛️", color: "from-indigo-500 to-blue-500", status: "Live" },
        { l: 4, title: "sabaos.layer4.title", desc: "sabaos.layer4.desc", icon: "🤖", color: "from-green-500 to-teal-500", status: "Live" },
        { l: 3, title: "sabaos.layer3.title", desc: "sabaos.layer3.desc", icon: "🧠", color: "from-yellow-500 to-orange-500", status: "Live" },
        { l: 2, title: "sabaos.layer2.title", desc: "sabaos.layer2.desc", icon: "💾", color: "from-red-500 to-pink-500", status: "Live" },
        { l: 1, title: "sabaos.layer1.title", desc: "sabaos.layer1.desc", icon: "🏗️", color: "from-slate-500 to-slate-400", status: "Live" },
      ].map((layer) => (
        <div class={`flex items-center gap-6 p-5 mb-3 rounded-xl bg-gradient-to-r ${layer.color} bg-opacity-10 border border-slate-700/50 hover:border-slate-500 transition-all`}>
          <div class="w-12 h-12 rounded-lg bg-slate-800/80 flex items-center justify-center text-2xl shrink-0">
            {layer.icon}
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-1">
              <span class="text-sm font-mono text-slate-400">L{layer.l}</span>
              <h3 class="text-lg font-bold text-slate-50" data-i18n={layer.title}>Layer {layer.l}</h3>
              <Badge variant="success" class="text-xs">{layer.status}</Badge>
            </div>
            <p class="text-slate-400 text-sm" data-i18n={layer.desc}>{layer.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Metrics -->
  <Section variant="light" padding="lg">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-5xl mx-auto">
