---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Button from "../../components/Button.astro";
import Badge from "../../components/Badge.astro";
---

<Layout title="QA Framework — SabaTech" description="The first QA framework built for AI-assisted development. Automated E2E testing, quality gates, and agentic test generation.">
	<script id="i18n-page-translations" type="application/json" set:html={JSON.stringify({
		en: {
			"qa.badge": "SaaS Platform",
			"qa.hero.title1": "QA",
			"qa.hero.title2": "Framework",
			"qa.hero.subtitle": "Ship with confidence. Every time.",
			"qa.hero.desc": "The first QA framework built for AI-assisted development. Automated E2E testing, code quality gates, and agentic test generation — all from a single platform.",
			"qa.hero.cta1": "Start Free Trial",
			"qa.hero.cta2": "See Features",
			"qa.features.title": "Features",
			"qa.features.subtitle": "Advanced tooling to ensure quality in your AI systems",
			"qa.workflow.badge": "How It Works",
			"qa.workflow.title": "Workflow",
			"qa.cta.title": "Interested in Early Access?",
			"qa.cta.desc": "Join the early access program for exclusive discounts, priority support, and the opportunity to shape the product.",
			"qa.cta.cta1": "Start Free Trial",
		},
		es: {
			"qa.badge": "Plataforma SaaS",
			"qa.hero.title1": "Framework",
			"qa.hero.title2": "QA",
			"qa.hero.subtitle": "Publica con confianza. Siempre.",
			"qa.hero.desc": "El primer framework QA diseñado para desarrollo asistido por IA. Testing E2E automatizado, puertas de calidad de código y generación agenética de tests — todo desde una única plataforma.",
			"qa.hero.cta1": "Iniciar Prueba Gratuita",
			"qa.hero.cta2": "Ver Funcionalidades",
			"qa.features.title": "Funcionalidades",
			"qa.features.subtitle": "Herramientas avanzadas para garantizar la calidad en tus sistemas de IA",
			"qa.workflow.badge": "Cómo Funciona",
			"qa.workflow.title": "Flujo de Trabajo",
			"qa.cta.title": "¿Interesado en el Acceso Anticipado?",
			"qa.cta.desc": "Únete al programa de acceso anticipado para descuentos exclusivos, soporte prioritario y la oportunidad de dar forma al producto.",
			"qa.cta.cta1": "Iniciar Prueba Gratuita",
		},
	})} />
	<Section variant="gradient" padding="xl">
		<div class="text-center">
			<Badge variant="primary" class="mb-6" data-i18n="qa.badge">SaaS Platform</Badge>
			<h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold mb-6 text-slate-50">
				<span data-i18n="qa.hero.title1">QA</span> <span class="bg-clip-text text-transparent bg-saba-gradient" data-i18n="qa.hero.title2">Framework</span>
			</h1>
			<p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-3xl mx-auto leading-relaxed" data-i18n="qa.hero.subtitle">
				Ship with confidence. Every time.
			</p>
			<p class="text-lg text-slate-400 mb-12 max-w-2xl mx-auto" data-i18n="qa.hero.desc">
				The first QA framework built for AI-assisted development. Automated E2E testing, code quality gates, and agentic test generation — all from a single platform.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<Button variant="primary" size="lg" href="/contact" data-i18n="qa.hero.cta1">Start Free Trial</Button>
				<Button variant="outline" size="lg" href="#features" data-i18n="qa.hero.cta2">See Features</Button>
			</div>
		</div>
	</Section>

	<Section variant="dark" padding="lg" id="features">
		<div class="text-center mb-16">
			<h2 class="text-3xl md:text-5xl font-bold mb-4 text-slate-50" data-i18n="qa.features.title">Features</h2>
			<p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="qa.features.subtitle">
				Advanced tooling to ensure quality in your AI systems
			</p>
		</div>

		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
						<svg aria-hidden="true" class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-slate-50">Test Management</h3>
					<p class="text-slate-400">Organize, prioritize, and execute tests with a unified dashboard. Suite planning and result tracking.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
						<svg aria-hidden="true" class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-slate-50">E2E Automation</h3>
					<p class="text-slate-400">Automated end-to-end tests for complete AI agent workflows. Playwright and Selenium integrated.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
						<svg aria-hidden="true" class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-slate-50">CI/CD Integration</h3>
					<p class="text-slate-400">Native integration with GitHub Actions, GitLab CI, and Jenkins. Run tests on every commit.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
						<svg aria-hidden="true" class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-slate-50">Quality Gates</h3>
					<p class="text-slate-400">Stop merges that don't meet your standards. Real-time coverage, defect density, and flakiness dashboards.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
						<svg aria-hidden="true" class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-slate-50">AI-Powered Tests</h3>
					<p class="text-slate-400">AI-generated tests adapted to your autonomous systems. Automatic test case optimization.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-teal-light flex items-center justify-center mb-6">
						<svg aria-hidden="true" class="w-8 h-8 text-teal-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-slate-50">Report Generation</h3>
					<p class="text-slate-400">Detailed execution reports with evidence. Export to PDF, HTML, and Jira/Linear integrations.</p>
				</div>
			</Card>
		</div>
	</Section>

	<Section variant="light" padding="lg">
		<div class="grid md:grid-cols-2 gap-12 items-center">
			<div>
				<Badge variant="success" class="mb-6" data-i18n="qa.workflow.badge">How It Works</Badge>
				<h2 class="text-3xl md:text-4xl font-bold mb-6 text-slate-50" data-i18n="qa.workflow.title">Workflow</h2>
				<div class="space-y-6">
					<div class="flex gap-4">
						<div class="w-10 h-10 rounded-full bg-saba-gradient text-white flex items-center justify-center shrink-0 font-bold">1</div>
						<div>
							<h3 class="text-lg font-semibold mb-2 text-slate-50">Define Test Cases</h3>
							<p class="text-slate-400">Create and organize test cases in the dashboard. Prioritize by risk and complexity.</p>
						</div>
					</div>
					<div class="flex gap-4">
						<div class="w-10 h-10 rounded-full bg-saba-gradient text-white flex items-center justify-center shrink-0 font-bold">2</div>
						<div>
							<h3 class="text-lg font-semibold mb-2 text-slate-50">Automate Execution</h3>
							<p class="text-slate-400">Run tests automatically in CI/CD or on-demand. Smart parallelization.</p>
						</div>
					</div>
					<div class="flex gap-4">
						<div class="w-10 h-10 rounded-full bg-saba-gradient text-white flex items-center justify-center shrink-0 font-bold">3</div>
						<div>
							<h3 class="text-lg font-semibold mb-2 text-slate-50">Analyze Results</h3>
							<p class="text-slate-400">Analyze quality metrics, detect regressions, and optimize coverage.</p>
						</div>
					</div>
					<div class="flex gap-4">
						<div class="w-10 h-10 rounded-full bg-saba-gradient text-white flex items-center justify-center shrink-0 font-bold">4</div>
						<div>
							<h3 class="text-lg font-semibold mb-2 text-slate-50">Iterate & Improve</h3>
							<p class="text-slate-400">Optimize test cases with AI. Continuous quality improvement.</p>
						</div>
					</div>
				</div>
			</div>

			<Card variant="elevated" class="p-8">
				<div class="text-center mb-6">
					<h3 class="text-2xl font-bold text-slate-50 mb-4">Roadmap</h3>
				</div>
				<ul class="space-y-4 text-slate-400">
					<li class="flex items-start gap-3">
						<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						<span><strong class="text-slate-200">Q2 2026:</strong> Private beta with early adopters</span>
					</li>
					<li class="flex items-start gap-3">
						<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						<span><strong class="text-slate-200">Q3 2026:</strong> GitHub Marketplace integration</span>
					</li>
					<li class="flex items-start gap-3">
						<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						<span><strong class="text-slate-200">Q4 2026:</strong> Public GA with pricing tiers</span>
					</li>
					<li class="flex items-start gap-3">
						<svg aria-hidden="true" class="w-5 h-5 text-teal-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						<span><strong class="text-slate-200">Q1 2027:</strong> Enterprise features and compliance</span>
					</li>
				</ul>
			</Card>
		</div>
	</Section>

	<Section variant="dark" padding="xl">
		<div class="text-center max-w-3xl mx-auto">
			<h2 class="text-3xl md:text-5xl font-bold mb-6 text-slate-50" data-i18n="qa.cta.title">Interested in Early Access?</h2>
			<p class="text-slate-300 text-lg mb-8 leading-relaxed" data-i18n="qa.cta.desc">
				Join the early access program for exclusive discounts, priority support, and the opportunity to shape the product.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<Button variant="primary" size="lg" href="/contact" data-i18n="qa.cta.cta1">Start Free Trial</Button>
				<Button variant="outline" size="lg" href="mailto:jmsabaris@sabatech.dev">jmsabaris@sabatech.dev</Button>
			</div>
		</div>
	</Section>
</Layout>
