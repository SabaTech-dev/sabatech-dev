---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Button from "../../components/Button.astro";
import Badge from "../../components/Badge.astro";
---

<Layout title="QA-Framework - SabaTech">
	<Section variant="gradient" padding="xl">
		<div class="text-center">
			<Badge variant="primary" class="mb-6">SaaS Platform</Badge>
			<h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6 text-white">
				QA-Framework
			</h1>
			<p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto leading-relaxed">
				Plataforma SaaS de testing automatizado para agentes IA y sistemas autónomos
			</p>
			<p class="text-lg text-gray-400 mb-12 max-w-2xl mx-auto">
				Automatiza E2E tests, integra CI/CD y obtén métricas de calidad en tiempo real para tus sistemas de inteligencia artificial
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<Button variant="primary" size="lg" href="/contact">Solicitar Early Access</Button>
				<Button variant="outline" size="lg" href="#features">Ver Características</Button>
			</div>
		</div>
	</Section>

	<Section variant="dark" padding="lg" id="features">
		<div class="text-center mb-16">
			<h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">Características</h2>
			<p class="text-gray-400 text-lg max-w-2xl mx-auto">
				Herramientas avanzadas para asegurar la calidad de tus sistemas de IA
			</p>
		</div>

		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">Test Management</h3>
					<p class="text-gray-400">Organiza, prioriza y ejecuta tests con un dashboard unificado. Planificación de suites y seguimiento de resultados.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">E2E Automation</h3>
					<p class="text-gray-400">Tests end-to-end automatizados para flujos completos de agentes AI. Playwright y Selenium integrados.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">CI/CD Integration</h3>
					<p class="text-gray-400">Integración nativa con GitHub Actions, GitLab CI y Jenkins. Ejecuta tests en cada commit.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">Quality Metrics</h3>
					<p class="text-gray-400">Métricas en tiempo real de coverage, defect density y flakiness. Dashboards personalizables.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">AI-Powered Tests</h3>
					<p class="text-gray-400">Tests generados por IA adaptados a tus sistemas autónomos. Optimización automática de casos de prueba.</p>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">Report Generation</h3>
					<p class="text-gray-400">Reportes detallados de ejecución con evidencias. Exportación a PDF, HTML y integraciones Jira/Linear.</p>
				</div>
			</Card>
		</div>
	</Section>

	<Section variant="light" padding="lg">
		<div class="grid md:grid-cols-2 gap-12 items-center">
			<div>
				<Badge variant="success" class="mb-6">How It Works</Badge>
				<h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">Flujo de Trabajo</h2>
				<div class="space-y-6">
					<div class="flex gap-4">
						<div class="w-10 h-10 rounded-full bg-primary-red text-white flex items-center justify-center shrink-0 font-bold">1</div>
						<div>
							<h3 class="text-lg font-semibold mb-2 text-white">Define Test Cases</h3>
							<p class="text-gray-400">Crea y organiza casos de prueba en el dashboard. Prioriza por riesgo y complejidad.</p>
						</div>
					</div>
					<div class="flex gap-4">
						<div class="w-10 h-10 rounded-full bg-primary-red text-white flex items-center justify-center shrink-0 font-bold">2</div>
						<div>
							<h3 class="text-lg font-semibold mb-2 text-white">Automate Execution</h3>
							<p class="text-gray-400">Ejecuta tests automáticamente en CI/CD o bajo demanda. Paralelización inteligente.</p>
						</div>
					</div>
					<div class="flex gap-4">
						<div class="w-10 h-10 rounded-full bg-primary-red text-white flex items-center justify-center shrink-0 font-bold">3</div>
						<div>
							<h3 class="text-lg font-semibold mb-2 text-white">Analyze Results</h3>
							<p class="text-gray-400">Analiza métricas de calidad, detecta regresiones y optimiza cobertura.</p>
						</div>
					</div>
					<div class="flex gap-4">
						<div class="w-10 h-10 rounded-full bg-primary-red text-white flex items-center justify-center shrink-0 font-bold">4</div>
						<div>
							<h3 class="text-lg font-semibold mb-2 text-white">Iterate & Improve</h3>
							<p class="text-gray-400">Optimiza casos de prueba con IA. Mejora continúa de la calidad del sistema.</p>
						</div>
					</div>
				</div>
			</div>

			<Card variant="elevated" class="p-8">
				<div class="text-center mb-6">
					<h3 class="text-2xl font-bold text-white mb-4">Próximos Pasos</h3>
				</div>
				<ul class="space-y-4 text-gray-400">
					<li class="flex items-start gap-3">
						<svg class="w-5 h-5 text-primary-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						<span><strong class="text-white">Q2 2026:</strong> Beta privada con early adopters</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-5 h-5 text-primary-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						<span><strong class="text-white">Q3 2026:</strong> Integrración con GitHub Marketplace</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-5 h-5 text-primary-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						<span><strong class="text-white">Q4 2026:</strong> GA pública con pricing tiers</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-5 h-5 text-primary-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
						</svg>
						<span><strong class="text-white">Q1 2027:</strong> Enterprise features y compliance</span>
					</li>
				</ul>
			</Card>
		</div>
	</Section>

	<Section variant="dark" padding="xl">
		<div class="text-center max-w-3xl mx-auto">
			<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white">¿Interesado en Early Access?</h2>
			<p class="text-gray-300 text-lg mb-8 leading-relaxed">
				Únete al programa de early access y obtén descuentos exclusivos, soporte prioritario y la oportunidad de influir en el desarrollo del producto.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<Button variant="primary" size="lg" href="mailto:jmsabaris@sabatech.dev">jmsabaris@sabatech.dev</Button>
				<Button variant="outline" size="lg" href="/contact">Formulario de contacto</Button>
			</div>
		</div>
	</Section>
</Layout>
