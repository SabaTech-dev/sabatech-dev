          <Button variant="outline" size="lg" href="#contact" data-i18n="jose.hero.cta2">
            Contáctame
          </Button>
        </div>

        <!-- Social links -->
        <div class="flex justify-center gap-4">
          <a href="https://github.com/SabaTech-dev" target="_blank" rel="noopener noreferrer" 
