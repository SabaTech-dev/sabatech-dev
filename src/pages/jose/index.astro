  <!-- Hero Section -->
  <Section variant="dark" padding="lg">
    <Container>
      <div class="max-w-4xl mx-auto text-center">
        <Badge variant="primary" class="mb-6" data-i18n="jose.badge">Perfil</Badge>
        
        <h1 class="text-5xl md:text-7xl font-extrabold mb-6">
