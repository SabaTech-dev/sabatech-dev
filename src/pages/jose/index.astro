              <div class="bg-slate-800 rounded-lg p-4 border border-slate-700">
                <h3 class="font-semibold text-pink-400 mb-2" data-i18n="jose.certs.item3">
                  Diploma de Fundamentos en Testing ISTQB
                </h3>
                <p class="text-slate-400 text-sm">International Software Testing Qualifications Board</p>
              </div>
            </div>
          </div>

          <!-- Right: Languages -->
          <div>
            <h2 class="text-3xl font-bold text-slate-50 mb-6" data-i18n="jose.languages">Idiomas</h2>
            <div class="space-y-4">
              <div class="bg-slate-800 rounded-lg p-4 border border-slate-700">
                <div class="flex items-center justify-between mb-2">
                  <span class="font-semibold text-slate-200">Español</span>
                  <span class="text-sm text-green-400">Nativo</span>
