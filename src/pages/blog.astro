---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import Badge from "../components/Badge.astro";
---

<Layout title="Blog | SabaTech" description="Blog de SabaTech: artículos sobre tecnología, IA, seguridad y desarrollo de software. QA, DevSecOps y orquestación de agentes autónomos.">
	<Section variant="dark" padding="lg">
		<Container>
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-12">
					<h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Blog</h1>
					<p class="text-gray-400 text-lg mb-8 leading-relaxed">
						Artículos sobre tecnología, IA, seguridad y desarrollo de software.
					</p>
				</div>

				<div class="grid md:grid-cols-2 gap-6 mb-12">
					<Card variant="elevated" hover>
						<div class="p-6">
							<div class="mb-4">
								<Badge variant="info">Próximamente</Badge>
							</div>
							<h3 class="text-xl font-bold text-white mb-2">QA para Agentes IA</h3>
							<p class="text-gray-400 mb-4 text-sm">
								Framework de automatización QA para testing de agentes autónomos. E2E, integración continua y métricas.
							</p>
							<Button variant="outline" size="sm" disabled>Leer más</Button>
						</div>
					</Card>

					<Card variant="elevated" hover>
						<div class="p-6">
							<div class="mb-4">
								<Badge variant="warning">Próximamente</Badge>
							</div>
							<h3 class="text-xl font-bold text-white mb-2">Security Audit de Agentes</h3>
							<p class="text-gray-400 mb-4 text-sm">
								OWASP AI ASI compliance, pentesting de agentes y evaluación de riesgos en sistemas de IA.
							</p>
							<Button variant="outline" size="sm" disabled>Leer más</Button>
						</div>
					</Card>

					<Card variant="elevated" hover>
						<div class="p-6">
							<div class="mb-4">
								<Badge variant="success">Próximamente</Badge>
							</div>
							<h3 class="text-xl font-bold text-white mb-2">Orquestación Multi-Agente</h3>
							<p class="text-gray-400 mb-4 text-sm">
								Arquitecturas de coordinación autónoma, gestión de workflows y patrones de comunicación.
							</p>
							<Button variant="outline" size="sm" disabled>Leer más</Button>
						</div>
					</Card>

					<Card variant="elevated" hover>
						<div class="p-6">
							<div class="mb-4">
								<Badge variant="danger">Próximamente</Badge>
							</div>
							<h3 class="text-xl font-bold text-white mb-2">DevSecOps para IA</h3>
							<p class="text-gray-400 mb-4 text-sm">
								CI/CD seguro para modelos de IA, scanning de vulnerabilidades y hardening de infraestructura.
							</p>
							<Button variant="outline" size="sm" disabled>Leer más</Button>
						</div>
					</Card>
				</div>

				<div class="text-center bg-gray-900 rounded-xl p-8 border border-gray-800">
					<p class="text-gray-400 mb-4">
						Estamos preparando contenido técnico y novedades sobre QA, security y orquestación de agentes IA.
					</p>
					<p class="text-gray-500 mb-6">Suscríbete para recibir actualizaciones.</p>
					<Button variant="primary" size="lg" href="mailto:josemsabaris@gmail.com">
						Recibir notificaciones
					</Button>
				</div>
			</div>
		</Container>
	</Section>
</Layout>
