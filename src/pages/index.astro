---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import Badge from "../components/Badge.astro";
import Hero from "../components/Hero.astro";
---

<Layout title="SabaTech - Consultoría QA & Security para Agentes IA">
	<!-- Hero Section -->
	<Hero
		badge="AI Security & QA Expertise"
		headline="SabaTech"
		subheadline="Consultoría QA & Security para Agentes IA"
		ctaText="Hablemos de tu proyecto"
		ctaHref="/contact"
		secondaryCtaText="Ver Servicios"
		secondaryCtaHref="#services"
		variant="gradient"
	/>

	<!-- Services Section -->
	<Section variant="dark" padding="lg" id="services">
		<div class="text-center mb-16">
			<h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">Nuestros Servicios</h2>
			<p class="text-gray-400 text-lg max-w-2xl mx-auto">
				Soluciones integrales para seguridad, calidad y orquestación de sistemas de IA autónomos
			</p>
		</div>

		<div class="grid md:grid-cols-3 gap-8">
			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
					</div>
					<h3 class="text-2xl font-bold mb-3 text-white">QA-Framework</h3>
					<p class="text-gray-400 mb-6 leading-relaxed">
						Framework de automatización QA para testing de agentes IA. Suite de pruebas E2E, integración continua y métricas de calidad.
					</p>
					<Button variant="outline" href="/qa-framework" class="w-full">Saber más</Button>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
						</svg>
					</div>
					<h3 class="text-2xl font-bold mb-3 text-white">Security Audit</h3>
					<p class="text-gray-400 mb-6 leading-relaxed">
						Auditorías de seguridad para sistemas de IA. OWASP AI ASI compliance, pentesting de agentes y evaluación de riesgos.
					</p>
					<Button variant="outline" href="/security" class="w-full">Saber más</Button>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
						</svg>
					</div>
					<h3 class="text-2xl font-bold mb-3 text-white">Orquestación IA</h3>
					<p class="text-gray-400 mb-6 leading-relaxed">
						Diseño e implementación de arquitecturas de orquestación para multi-agent systems. Gestión de workflows y coordinación autónoma.
					</p>
					<Button variant="outline" href="/orquestacion" class="w-full">Saber más</Button>
				</div>
			</Card>
		</div>
	</Section>

	<!-- Why SabaTech Section -->
	<Section variant="light" padding="lg" id="why-sabatech">
		<div class="grid md:grid-cols-2 gap-12 items-center">
			<div>
				<Badge variant="success" class="mb-6">Why SabaTech</Badge>
				<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white">¿Por qué elegirnos?</h2>
				<p class="text-gray-400 text-lg mb-8 leading-relaxed">
					Combinamos experiencia en QA, DevSecOps e IA para ofrecer soluciones de seguridad y calidad de vanguardia para sistemas autónomos.
				</p>

				<div class="space-y-6">
					<div class="flex gap-4">
						<div class="w-12 h-12 rounded-lg bg-primary-red-light flex items-center justify-center shrink-0">
							<svg class="w-6 h-6 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-semibold mb-2 text-white">OWASP AI ASI Compliance</h3>
							<p class="text-gray-400">Auditorías alineadas con el estándar de seguridad para sistemas de IA OWASP</p>
						</div>
					</div>

					<div class="flex gap-4">
						<div class="w-12 h-12 rounded-lg bg-primary-red-light flex items-center justify-center shrink-0">
							<svg class="w-6 h-6 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-semibold mb-2 text-white">Rapidez y Eficiencia</h3>
							<p class="text-gray-400">Entregas ágiles con metodologías de prueba automatizada y CI/CD</p>
						</div>
					</div>

					<div class="flex gap-4">
						<div class="w-12 h-12 rounded-lg bg-primary-red-light flex items-center justify-center shrink-0">
							<svg class="w-6 h-6 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-semibold mb-2 text-white">Métricas y Reporting</h3>
							<p class="text-gray-400">Dashboards en tiempo real y reportes detallados de calidad y seguridad</p>
						</div>
					</div>

					<div class="flex gap-4">
						<div class="w-12 h-12 rounded-lg bg-primary-red-light flex items-center justify-center shrink-0">
							<svg class="w-6 h-6 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-semibold mb-2 text-white">Equipo Híbrido Humano-IA</h3>
							<p class="text-gray-400">Saba + Alfred (AI Co-Founder) para máxima eficiencia y especialización</p>
						</div>
					</div>
				</div>
			</div>

			<div class="relative">
				<div class="aspect-square rounded-2xl bg-gradient-to-br from-gray-800 to-gray-900 p-8 border border-gray-700">
					<div class="h-full flex flex-col justify-center items-center text-center">
						<svg class="w-32 h-32 text-primary-red mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
						</svg>
						<h3 class="text-3xl font-bold text-white mb-4">Seguridad Garantizada</h3>
						<p class="text-gray-400 text-lg">Protección de primer nivel para tus sistemas de IA</p>
					</div>
				</div>
			</div>
		</div>
	</Section>

	<!-- CTA Section -->
	<Section variant="gradient" padding="xl">
		<div class="text-center max-w-3xl mx-auto">
			<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white">¿Listo para mejorar la seguridad y calidad de tus agentes IA?</h2>
			<p class="text-gray-300 text-lg mb-8 leading-relaxed">
				Contáctanos para una consultoría gratuita sobre cómo podemos ayudarte a implementar frameworks de QA, seguridad y orquestación en tus sistemas de IA.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<Button variant="primary" size="lg" href="mailto:josemsabaris@gmail.com">josemsabaris@gmail.com</Button>
				<Button variant="outline" size="lg" href="/contact">Formulario de contacto</Button>
			</div>
		</div>
	</Section>
</Layout>
