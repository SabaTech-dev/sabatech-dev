<Layout title="Security Audit — SabaTech" description="AI security audits for agentic applications. OWASP Agentic Apps 2026, EU AI Act, NIST AI RMF compliance. Pentesting and vulnerability assessment.">
	<Section variant="gradient" padding="xl">
		<div class="text-center">
			<Badge variant="error" class="mb-6">OWASP AI Security — Agentic Apps 2026 + EU AI Act</Badge>
			<h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold mb-6 text-slate-50">
				Security <span class="bg-clip-text text-transparent bg-saba-gradient">Audit</span>
