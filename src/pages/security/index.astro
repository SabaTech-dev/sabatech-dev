---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import Button from "../../components/Button.astro";
import Badge from "../../components/Badge.astro";
import Container from "../components/Container.astro";
---

<Layout title="Security Audit - SabaTech">
	<Section variant="gradient" padding="xl">
		<div class="text-center">
			<Badge variant="error" class="mb-6">OWASP AI Security — Agentic Apps 2026 + EU AI Act</Badge>
			<h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6 text-white">
				Security Audit
			</h1>
			<p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto leading-relaxed">
				Auditorías de seguridad especializadas para sistemas de IA y agentes autónomos
			</p>
			<p class="text-lg text-gray-400 mb-12 max-w-2xl mx-auto">
				Compliance OWASP Top 10 for Agentic Applications 2026, EU AI Act, NIST AI RMF. Pentesting de agentes, evaluación de riesgos y hardening de infraestructura para AI systems.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<Button variant="primary" size="lg" href="/contact">Solicitar Auditoría</Button>
				<Button variant="outline" size="lg" href="#services">Ver Servicios</Button>
			</div>
		</div>
	</Section>

	<Section variant="dark" padding="lg" id="services">
		<div class="text-center mb-16">
			<h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">Servicios de Seguridad</h2>
			<p class="text-gray-400 text-lg max-w-2xl mx-auto">
				Cobertura completa de seguridad para el ciclo de vida de sistemas de IA
			</p>
		</div>

		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">OWASP Agentic Apps 2026</h3>
					<p class="text-gray-400 mb-6">Auditorías alineadas con OWASP Top 10 for Agentic Applications 2026. Evaluación de los 10 riesgos críticos para agentes autónomos.</p>
					<Badge variant="error">10/10 Coverage</Badge>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">EU AI Act Compliance</h3>
					<p class="text-gray-400 mb-6">Evaluación de riesgo AI Act (alto/medio/bajo), documentación de compliance, preparación para AI sandbox y reporting obligatorio.</p>
					<Badge variant="warning">EU Regulation</Badge>
				</div>
			</Card>

			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">NIST AI RMF Evaluation</h3>
					<p class="text-gray-400 mb-6">Evaluación completa según NIST AI Risk Management Framework: Govern, Map, Measure, Manage. Métricas y tracking continuo.</p>
