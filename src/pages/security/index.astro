			<Card variant="elevated" hover>
				<div class="p-8">
					<div class="w-14 h-14 rounded-lg bg-primary-red-light flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-primary-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3 text-white">Hardening de Infra</h3>
