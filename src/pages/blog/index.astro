---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import Container from "../../components/Container.astro";
import Card from "../../components/Card.astro";
import Badge from "../../components/Badge.astro";
import Button from "../../components/Button.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function getReadingTime(content: string) {
  const wordsPerMinute = 200;
  const words = content.split(/\s+/).length;
  return Math.ceil(words / wordsPerMinute);
}
---

<Layout title="Blog — SabaTech" description="Technical articles on AI security, QA automation, DevSecOps, and multi-agent orchestration.">
  <Section variant="dark" padding="lg">
    <Container>
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-extrabold text-slate-50 mb-4">Blog</h1>
          <p class="text-slate-400 text-lg mb-8 leading-relaxed">
            Technical insights on AI security, QA automation, DevSecOps, and multi-agent orchestration.
          </p>
        </div>

        {posts.length > 0 ? (
          <div class="grid gap-8">
            {posts.map((post) => (
              <a href={`/blog/${post.id}`} class="block group">
                <Card variant="elevated" hover>
                  <div class="p-8">
                    <div class="flex items-center gap-3 mb-4">
                      <time datetime={post.data.pubDate.toISOString()} class="text-slate-500 text-sm">
                        {formatDate(post.data.pubDate)}
                      </time>
                      <span class="text-slate-600">·</span>
                      <span class="text-slate-500 text-sm">By {post.data.author}</span>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-50 mb-3 group-hover:text-teal-brand transition-colors">
                      {post.data.title}
                    </h2>
                    <p class="text-slate-400 mb-4 leading-relaxed">{post.data.description}</p>
                    <div class="flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <Badge variant="primary" size="sm">{tag}</Badge>
                      ))}
                    </div>
                  </div>
                </Card>
              </a>
            ))}
          </div>
        ) : (
          <div class="text-center bg-slate-800/50 rounded-xl p-8 border border-slate-700">
            <p class="text-slate-400 mb-4">No posts yet. Check back soon!</p>
          </div>
        )}

        <div class="text-center mt-12 bg-slate-800/50 rounded-xl p-8 border border-slate-700">
          <p class="text-slate-400 mb-4">Subscribe to receive updates on AI security and QA automation.</p>
          <Button variant="primary" size="lg" href="mailto:jmsabaris@sabatech.dev">
            Get Notified
          </Button>
        </div>
      </div>
    </Container>
  </Section>
</Layout>
