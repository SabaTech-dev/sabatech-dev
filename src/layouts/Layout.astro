---
import "../styles/tokens.css";
import Container from "../components/Container.astro";

const { title = "SabaTech" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="SabaTech - Consultoría QA & Security para Agentes IA. Auditorías de seguridad, orquestación de IA y framework de automatización QA." />
		<meta name="author" content="SabaTech" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="SabaTech - Consultoría QA & Security para Agentes IA" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.sabatech.dev" />
		<meta property="og:image" content="/og-image.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content="SabaTech - Consultoría QA & Security para Agentes IA" />
		<meta name="twitter:image" content="/og-image.png" />
		<title>{title}</title>
	</head>
	<body>
		<header class="border-b border-gray-800 bg-black/95 backdrop-blur-sm sticky top-0 z-50">
			<Container>
				<nav class="flex items-center justify-between h-16 md:h-20">
					<a href="/" class="flex items-center gap-2 text-white hover:text-primary-red transition-colors">
						<span class="text-2xl font-bold">SabaTech</span>
					</a>

					<!-- Desktop Nav -->
					<ul class="hidden md:flex items-center gap-1">
						<li><a href="/" class="px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Inicio</a></li>
						<li><a href="/qa-framework" class="px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">QA-Framework</a></li>
						<li><a href="/security" class="px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Security</a></li>
						<li><a href="/orquestacion" class="px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Orquestación</a></li>
						<li><a href="/about" class="px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Sobre Nosotros</a></li>
						<li><a href="/team" class="px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Equipo</a></li>
						<li><a href="/contact" class="px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Contacto</a></li>
					</ul>

					<!-- Mobile Menu Button -->
					<button
						id="mobile-menu-button"
						class="md:hidden p-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg"
						aria-label="Menu"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</button>
				</nav>

				<!-- Mobile Menu -->
				<div id="mobile-menu" class="hidden md:hidden py-4 border-t border-gray-800">
					<ul class="flex flex-col gap-1">
						<li><a href="/" class="block px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Inicio</a></li>
						<li><a href="/qa-framework" class="block px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">QA-Framework</a></li>
						<li><a href="/security" class="block px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Security</a></li>
						<li><a href="/orquestacion" class="block px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Orquestación</a></li>
						<li><a href="/about" class="block px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Sobre Nosotros</a></li>
						<li><a href="/team" class="block px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Equipo</a></li>
						<li><a href="/contact" class="block px-4 py-2 text-gray-300 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">Contacto</a></li>
					</ul>
				</div>
			</Container>
		</header>

		<main>
			<slot />
		</main>

		<footer class="border-t border-gray-800 bg-black">
			<Container>
				<div class="py-12">
					<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
						<!-- Brand -->
						<div class="md:col-span-2">
							<h3 class="text-xl font-bold text-white mb-4">SabaTech</h3>
							<p class="text-gray-400 mb-4 max-w-md">
								Consultoría QA & Security para Agentes IA. Auditorías de seguridad, orquestación de IA y framework de automatización QA.
							</p>
							<div class="flex gap-4">
								<a href="https://github.com/SabaTech-dev" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">
									<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
								</a>
								<a href="https://twitter.com/LJokerL_TTV" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">
									<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
								</a>
							</div>
						</div>

						<!-- Links -->
						<div>
							<h4 class="font-semibold text-white mb-4">Servicios</h4>
							<ul class="space-y-2">
								<li><a href="/qa-framework" class="text-gray-400 hover:text-white transition-colors">QA-Framework</a></li>
								<li><a href="/security" class="text-gray-400 hover:text-white transition-colors">Security Audit</a></li>
								<li><a href="/orquestacion" class="text-gray-400 hover:text-white transition-colors">Orquestación IA</a></li>
							</ul>
						</div>

						<div>
							<h4 class="font-semibold text-white mb-4">Compañía</h4>
							<ul class="space-y-2">
								<li><a href="/about" class="text-gray-400 hover:text-white transition-colors">Sobre Nosotros</a></li>
								<li><a href="/team" class="text-gray-400 hover:text-white transition-colors">Equipo</a></li>
								<li><a href="/contact" class="text-gray-400 hover:text-white transition-colors">Contacto</a></li>
							</ul>
						</div>
					</div>

					<!-- Bottom -->
					<div class="pt-8 mt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4">
						<p class="text-gray-500 text-sm">
							&copy; 2026 SabaTech. Todos los derechos reservados.
						</p>
						<div class="flex gap-6 text-sm">
							<a href="/privacy" class="text-gray-500 hover:text-white transition-colors">Privacidad</a>
							<a href="/terms" class="text-gray-500 hover:text-white transition-colors">Términos</a>
							<a href="/cookies" class="text-gray-500 hover:text-white transition-colors">Cookies</a>
						</div>
					</div>
				</div>
			</Container>
		</footer>

		<script>
			const mobileMenuButton = document.getElementById("mobile-menu-button");
			const mobileMenu = document.getElementById("mobile-menu");

			mobileMenuButton?.addEventListener("click", () => {
				mobileMenu?.classList.toggle("hidden");
			});
		</script>
	</body>
</html>
