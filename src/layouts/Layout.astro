---
import "../styles/global.css";
import Container from "../components/Container.astro";
import Logo from "../components/Logo.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: object;
}

const {
  title = "SabaTech — Agentic QA Automation & Security for the AI Era",
  description = "SabaTech: Agentic QA Automation & Security for the AI Era. AI-powered security audits, automated QA testing, and multi-agent orchestration for development teams.",
  ogImage = "/og-image.png",
  ogType = "website",
  canonicalUrl,
  jsonLd,
} = Astro.props;

const siteUrl = "https://sabatech.dev";
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="SabaTech" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="SabaTech" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self';" />

    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="bg-midnight text-slate-50 antialiased">
    <header class="border-b border-slate-800 bg-midnight/95 backdrop-blur-sm sticky top-0 z-50">
      <Container>
        <nav class="flex items-center justify-between h-16 md:h-20">
          <!-- Logo: horizontal on desktop, icon-only on mobile -->
          <div class="md:hidden">
            <Logo variant="icon-only" href="/" />
          </div>
          <div class="hidden md:block">
            <Logo variant="horizontal" href="/" />
          </div>

          <!-- Desktop Nav -->
          <ul class="hidden lg:flex items-center gap-1">
            <li><a href="/" data-i18n="nav.home" class="px-3 py-2 text-sm text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Home</a></li>
            <li><a href="/qa-framework" data-i18n="nav.qa-framework" class="px-3 py-2 text-sm text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">QA Framework</a></li>
            <li><a href="/security" data-i18n="nav.security" class="px-3 py-2 text-sm text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Security</a></li>
            <li><a href="/saba-agent-os" class="px-3 py-2 text-sm text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Saba-Agent-OS</a></li>
            <li><a href="/pricing" data-i18n="nav.pricing" class="px-3 py-2 text-sm text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Pricing</a></li>
            <li><a href="/about" data-i18n="nav.about" class="px-3 py-2 text-sm text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">About</a></li>
            <li><a href="/team" data-i18n="nav.team" class="px-3 py-2 text-sm text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Team</a></li>
            <li><a href="/jose" data-i18n="nav.jose" class="px-3 py-2 text-sm text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Jose</a></li>
            <li><a href="/blog" data-i18n="nav.blog" class="px-3 py-2 text-sm text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Blog</a></li>
            <li class="ml-2 flex items-center gap-2">
              <!-- Language Toggle -->
              <button
                id="lang-toggle"
                type="button"
                class="px-2.5 py-1.5 text-xs font-bold text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors border border-slate-700"
                aria-label="Switch language"
              >
                EN | ES
              </button>
              <a href="/contact" data-i18n="nav.startAudit" class="px-5 py-2 bg-teal-brand hover:bg-teal-hover text-midnight font-semibold rounded-lg transition-colors">
                Start Free Audit
              </a>
            </li>
          </ul>

          <!-- Mobile Menu Button -->
          <div class="lg:hidden flex items-center gap-2">
            <button
              id="lang-toggle-mobile"
              type="button"
              class="p-2 text-xs font-bold text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg border border-slate-700"
              aria-label="Switch language"
            >
              EN | ES
            </button>
            <button
              id="mobile-menu-button"
              class="p-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg"
              aria-label="Menu"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </nav>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden lg:hidden py-4 border-t border-slate-800">
          <ul class="flex flex-col gap-1">
            <li><a href="/" data-i18n="nav.home" class="mobile-nav-link block px-4 py-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Home</a></li>
            <li><a href="/qa-framework" data-i18n="nav.qa-framework" class="mobile-nav-link block px-4 py-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">QA Framework</a></li>
            <li><a href="/security" data-i18n="nav.security" class="mobile-nav-link block px-4 py-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Security</a></li>
            <li><a href="/saba-agent-os" class="mobile-nav-link block px-4 py-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Saba-Agent-OS</a></li>
            <li><a href="/pricing" data-i18n="nav.pricing" class="mobile-nav-link block px-4 py-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Pricing</a></li>
            <li><a href="/about" data-i18n="nav.about" class="mobile-nav-link block px-4 py-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">About</a></li>
            <li><a href="/team" data-i18n="nav.team" class="mobile-nav-link block px-4 py-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Team</a></li>
            <li><a href="/jose" data-i18n="nav.jose" class="mobile-nav-link block px-4 py-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Jose</a></li>
            <li><a href="/blog" data-i18n="nav.blog" class="mobile-nav-link block px-4 py-2 text-slate-400 hover:text-slate-50 hover:bg-slate-800 rounded-lg transition-colors">Blog</a></li>
            <li>
              <a href="/contact" data-i18n="nav.startAudit" class="block px-4 py-2 bg-teal-brand text-midnight font-semibold rounded-lg mt-2 text-center">
                Start Free Audit
              </a>
            </li>
          </ul>
        </div>
      </Container>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-slate-800 bg-midnight">
      <Container>
        <div class="py-12">
          <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <!-- Brand with Logo (stacked) -->
            <div class="md:col-span-2">
              <Logo variant="horizontal" href="/" class="mb-4" />
              <p data-i18n="footer.desc" class="text-slate-400 mb-4 max-w-md leading-relaxed">
                Agentic QA Automation & Security for the AI Era. AI-powered security audits, automated testing, and multi-agent orchestration — protected by our AI agents.
              </p>
              <div class="flex gap-4">
                <a href="https://github.com/SabaTech-dev" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-teal-brand transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
                <a href="https://twitter.com/LJokerL_TTV" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-teal-brand transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
                </a>
              </div>
            </div>

            <!-- Links -->
            <div>
              <h4 data-i18n="footer.services" class="font-semibold text-slate-200 mb-4">Services</h4>
              <ul class="space-y-2">
                <li><a href="/qa-framework" data-i18n="footer.services.qa" class="text-slate-500 hover:text-teal-brand transition-colors">QA Framework</a></li>
                <li><a href="/security" data-i18n="footer.services.security" class="text-slate-500 hover:text-teal-brand transition-colors">Security Audit</a></li>
                <li><a href="/saba-agent-os" class="text-slate-500 hover:text-teal-brand transition-colors">Saba-Agent-OS</a></li>
                <li><a href="/pricing" data-i18n="footer.services.pricing" class="text-slate-500 hover:text-teal-brand transition-colors">Pricing</a></li>
              </ul>
            </div>

            <div>
              <h4 data-i18n="footer.company" class="font-semibold text-slate-200 mb-4">Company</h4>
              <ul class="space-y-2">
                <li><a href="/about" data-i18n="footer.company.about" class="text-slate-500 hover:text-teal-brand transition-colors">About Us</a></li>
                <li><a href="/team" data-i18n="footer.company.team" class="text-slate-500 hover:text-teal-brand transition-colors">Team</a></li>
                <li><a href="/blog" data-i18n="footer.company.blog" class="text-slate-500 hover:text-teal-brand transition-colors">Blog</a></li>
                <li><a href="/contact" data-i18n="footer.company.contact" class="text-slate-500 hover:text-teal-brand transition-colors">Contact</a></li>
              </ul>
            </div>
          </div>

          <!-- Bottom -->
          <div class="pt-8 mt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4">
            <p data-i18n="footer.copyright" class="text-slate-600 text-sm">
              &copy; 2026 SabaTech. All rights reserved.
            </p>
            <div class="flex gap-6 text-sm">
              <a href="/privacy" data-i18n="footer.privacy" class="text-slate-600 hover:text-slate-300 transition-colors">Privacy</a>
              <a href="/terms" data-i18n="footer.terms" class="text-slate-600 hover:text-slate-300 transition-colors">Terms</a>
              <a href="/cookies" data-i18n="footer.cookies" class="text-slate-600 hover:text-slate-300 transition-colors">Cookies</a>
            </div>
          </div>
        </div>
      </Container>
    </footer>

    <script>
      // Mobile menu toggle
      const mobileMenuButton = document.getElementById("mobile-menu-button");
      const mobileMenu = document.getElementById("mobile-menu");

      mobileMenuButton?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
      });

      // Close mobile menu when a nav link is clicked
      document.querySelectorAll(".mobile-nav-link").forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu?.classList.add("hidden");
        });
      });
    </script>

    <script>
      // i18n client-side language switching
      const LANG_KEY = "sabatech-lang";

      const translations = {
        en: {
          "nav.home": "Home",
          "nav.qa-framework": "QA Framework",
          "nav.security": "Security",
          "nav.orchestration": "Orchestration",
          "nav.pricing": "Pricing",
          "nav.about": "About",
          "nav.team": "Team",
          "nav.jose": "Jose",
          "nav.blog": "Blog",
          "nav.startAudit": "Start Free Audit",
          "footer.desc": "Agentic QA Automation & Security for the AI Era. AI-powered security audits, automated testing, and multi-agent orchestration — protected by our AI agents.",
          "footer.services": "Services",
          "footer.services.qa": "QA Framework",
          "footer.services.security": "Security Audit",
          "footer.services.orchestration": "AI Orchestration",
          "footer.services.pricing": "Pricing",
          "footer.company": "Company",
          "footer.company.about": "About Us",
          "footer.company.team": "Team",
          "footer.company.blog": "Blog",
          "footer.company.contact": "Contact",
          "footer.copyright": "\u00a9 2026 SabaTech. All rights reserved.",
          "footer.privacy": "Privacy",
          "footer.terms": "Terms",
          "footer.cookies": "Cookies",
        },
        es: {
          "nav.home": "Inicio",
          "nav.qa-framework": "Framework QA",
          "nav.security": "Seguridad",
          "nav.orchestration": "Orquestaci\u00f3n",
          "nav.pricing": "Precios",
          "nav.about": "Nosotros",
          "nav.team": "Equipo",
          "nav.jose": "Jose",
          "nav.blog": "Blog",
          "nav.startAudit": "Auditor\u00eda Gratuita",
          "footer.desc": "Automatizaci\u00f3n QA Agen\u00e9tica y Seguridad para la Era de la IA. Auditor\u00edas de seguridad con IA, testing automatizado y orquestaci\u00f3n multiagente — protegidos por nuestros agentes de IA.",
          "footer.services": "Servicios",
          "footer.services.qa": "Framework QA",
          "footer.services.security": "Auditor\u00eda de Seguridad",
          "footer.services.orchestration": "Orquestaci\u00f3n IA",
          "footer.services.pricing": "Precios",
          "footer.company": "Empresa",
          "footer.company.about": "Sobre Nosotros",
          "footer.company.team": "Equipo",
          "footer.company.blog": "Blog",
          "footer.company.contact": "Contacto",
          "footer.copyright": "\u00a9 2026 SabaTech. Todos los derechos reservados.",
          "footer.privacy": "Privacidad",
          "footer.terms": "T\u00e9rminos",
          "footer.cookies": "Cookies",
        },
      };

      // Merge page-specific translations from the data-i18n-json script tag
      const pageTranslationsEl = document.getElementById("i18n-page-translations");
      let pageTranslations: Record<string, Record<string, string>> = {};
      if (pageTranslationsEl) {
        try {
          pageTranslations = JSON.parse(pageTranslationsEl.textContent || "{}");
        } catch { /* ignore */ }
      }

      // Merge page translations into main translations
      for (const lang of Object.keys(pageTranslations)) {
        if (!translations[lang as "en" | "es"]) continue;
        Object.assign(translations[lang as "en" | "es"], pageTranslations[lang]);
      }

      function getCurrentLang(): string {
        return localStorage.getItem(LANG_KEY) || "en";
      }

      function setLang(lang: string): void {
        localStorage.setItem(LANG_KEY, lang);
        applyTranslations(lang);
        updateToggleButton(lang);
      }

      function applyTranslations(lang: string): void {
        const dict = translations[lang as "en" | "es"] || translations.en;
        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.getAttribute("data-i18n");
          if (key && dict[key]) {
            el.textContent = dict[key];
          }
        });
        // Also update the html lang attribute
        document.documentElement.lang = lang;
      }

      function updateToggleButton(lang: string): void {
        const btn = document.getElementById("lang-toggle");
        const btnMobile = document.getElementById("lang-toggle-mobile");
        const label = lang === "en" ? "EN | ES" : "ES | EN";
        if (btn) btn.textContent = label;
        if (btnMobile) btnMobile.textContent = label;
      }

      function toggleLang(): void {
        const current = getCurrentLang();
        const next = current === "en" ? "es" : "en";
        setLang(next);
      }

      // Initialize on page load
      const currentLang = getCurrentLang();
      if (currentLang !== "en") {
        applyTranslations(currentLang);
      }
      updateToggleButton(currentLang);

      // Bind toggle buttons
      document.getElementById("lang-toggle")?.addEventListener("click", toggleLang);
      document.getElementById("lang-toggle-mobile")?.addEventListener("click", toggleLang);
    </script>
  </body>
</html>
